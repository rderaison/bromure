<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE dictionary SYSTEM "file://localhost/System/Library/DTDs/sdef.dtd">
<dictionary title="Bromure Agentic Coding Scripting Dictionary">

    <suite name="Standard Suite" code="????" description="Common classes and commands for all applications.">
        <command name="quit" code="aevtquit" description="Quit the application.">
            <cocoa class="NSQuitCommand"/>
        </command>
    </suite>

    <suite name="Bromure AC Suite" code="BrAC" description="Commands for orchestrating Bromure Agentic Coding — profile management, locale switching, and editor navigation for screenshot tooling.">

        <!-- ============================================================ -->
        <!-- Inspection                                                   -->
        <!-- ============================================================ -->

        <command name="get app state" code="BrAcGtSt" description="Returns a JSON object: { locale, mainWindowOpen, editorOpen, editorCategory, profiles: [...] }.">
            <cocoa class="BromureACGetAppStateCommand"/>
            <result type="text" description="JSON object"/>
        </command>

        <command name="list profiles" code="BrAcLsPr" description="JSON array of { id, name, color }.">
            <cocoa class="BromureACListProfilesCommand"/>
            <result type="text" description="JSON array"/>
        </command>

        <!-- ============================================================ -->
        <!-- Profile management                                           -->
        <!-- ============================================================ -->

        <command name="create ac profile" code="BrAcCrPr" description="Create a new profile with the given name. Returns the new profile's UUID.">
            <cocoa class="BromureACCreateProfileCommand"/>
            <direct-parameter type="text" description="Profile name"/>
            <parameter name="color" code="pCol" type="text" optional="yes" description="Window border color: blue, red, green, orange, purple, pink, teal, gray"/>
            <result type="text" description="Profile UUID"/>
        </command>

        <command name="delete ac profile" code="BrAcDlPr" description="Delete a profile by name or UUID.">
            <cocoa class="BromureACDeleteProfileCommand"/>
            <direct-parameter type="text" description="Profile name or UUID"/>
        </command>

        <!-- ============================================================ -->
        <!-- Window navigation (driven by the screenshot script)          -->
        <!-- ============================================================ -->

        <command name="open profile manager" code="BrAcOpPm" description="Bring the profile picker (main window) to the front.">
            <cocoa class="BromureACOpenProfileManagerCommand"/>
        </command>

        <command name="open ac profile editor" code="BrAcOpEd" description="Open the editor for a profile by name or UUID.">
            <cocoa class="BromureACOpenProfileEditorCommand"/>
            <direct-parameter type="text" description="Profile name or UUID"/>
            <result type="text" description="'ok' on success or 'error: …' otherwise"/>
        </command>

        <command name="close ac profile editor" code="BrAcClEd" description="Close the editor window if open.">
            <cocoa class="BromureACCloseProfileEditorCommand"/>
            <result type="text" description="'ok'"/>
        </command>

        <command name="select editor category" code="BrAcSlCt" description="Switch the editor sidebar to the given category. Names (spaces and case ignored): general, agents, fusion, folders, credentials, environment, mcp, tracing, guardrails, supplychain, promptinjection, appearance, resources.">
            <cocoa class="BromureACSelectEditorCategoryCommand"/>
            <direct-parameter type="text" description="Category key"/>
            <result type="text" description="'ok' or 'error: …'"/>
        </command>

        <command name="get editor window id" code="BrAcGtId" description="Returns the CGWindowID of the editor window, or 0 if not open. Use with `screencapture -l ID` from the shell.">
            <cocoa class="BromureACGetEditorWindowIDCommand"/>
            <result type="integer" description="CGWindowID"/>
        </command>

        <command name="get main window id" code="BrAcGtMI" description="Returns the CGWindowID of the picker (main) window, or 0 if not open.">
            <cocoa class="BromureACGetMainWindowIDCommand"/>
            <result type="integer" description="CGWindowID"/>
        </command>

        <!-- ============================================================ -->
        <!-- Profile settings — used by Tests/ac-e2e.mjs                  -->
        <!-- ============================================================ -->

        <command name="get profile json" code="BrAcGtPJ" description="Return the full profile (including nested credentials, MCP servers, etc.) as a JSON-encoded Profile.">
            <cocoa class="BromureACGetProfileJSONCommand"/>
            <direct-parameter type="text" description="Profile name or UUID"/>
            <result type="text" description="JSON Profile blob"/>
        </command>

        <command name="set profile json" code="BrAcStPJ" description="Replace the full profile from a JSON blob. The profile's id is preserved.">
            <cocoa class="BromureACSetProfileJSONCommand"/>
            <direct-parameter type="text" description="Profile name or UUID"/>
            <parameter name="to value" code="pVal" type="text" description="JSON-encoded Profile"/>
            <result type="text" description="'ok' or 'error: …'"/>
        </command>

        <command name="get profile setting" code="BrAcGtPS" description="Read one simple profile field. Keys: name, color, comments, tool, authMode, apiKey, closeAction, memoryGB, folderPath, folderPathsCount, mcpServerCount, keyboardLayoutOverride, keyRepeatDelayMs, keyRepeatRateHz.">
            <cocoa class="BromureACGetProfileSettingCommand"/>
            <direct-parameter type="text" description="Profile name or UUID"/>
            <parameter name="key" code="pKey" type="text" description="Setting key"/>
            <result type="text" description="Setting value, or 'error: …'"/>
        </command>

        <command name="set profile setting" code="BrAcStPS" description="Write one simple profile field. See `get profile setting` for the supported keys.">
            <cocoa class="BromureACSetProfileSettingCommand"/>
            <direct-parameter type="text" description="Profile name or UUID"/>
            <parameter name="key" code="pKey" type="text" description="Setting key"/>
            <parameter name="to value" code="pVal" type="text" description="Setting value (as text)"/>
            <result type="text" description="'ok' or 'error: …'"/>
        </command>

        <!-- ============================================================ -->
        <!-- Session control                                              -->
        <!-- ============================================================ -->

        <command name="open ac session" code="BrAcOpSe" description="Launch a session window for the given profile. Returns the profile UUID (sessions are 1:1 with profiles in AC).">
            <cocoa class="BromureACOpenSessionCommand"/>
            <direct-parameter type="text" description="Profile name or UUID"/>
            <result type="text" description="Profile UUID, or 'error: …'"/>
        </command>

        <command name="close ac session" code="BrAcClSe" description="Close any active session window for the given profile.">
            <cocoa class="BromureACCloseSessionCommand"/>
            <direct-parameter type="text" description="Profile name or UUID"/>
            <result type="text" description="'ok' or 'error: …'"/>
        </command>

        <command name="list ac sessions" code="BrAcLsSe" description="JSON array of currently-open session windows: { profileId, profileName, windowId, visible }.">
            <cocoa class="BromureACListSessionsCommand"/>
            <result type="text" description="JSON array"/>
        </command>

        <!-- ============================================================ -->
        <!-- App-wide settings                                            -->
        <!-- ============================================================ -->

        <command name="get ac app setting" code="BrAcGtAS" description="Read an app-wide setting (UserDefaults). Keys: automation.enabled, automation.port, automation.bindAddress, managed.serverURL, managed.acIngestURL.">
            <cocoa class="BromureACGetAppSettingCommand"/>
            <direct-parameter type="text" description="Setting key"/>
            <result type="text" description="Setting value, or 'error: …'"/>
        </command>

        <command name="set ac app setting" code="BrAcStAS" description="Write an app-wide setting. Booleans as 'true'/'false'; integers as digit strings. Setting automation.enabled toggles the HTTP server live.">
            <cocoa class="BromureACSetAppSettingCommand"/>
            <direct-parameter type="text" description="Setting key"/>
            <parameter name="to value" code="pVal" type="text" description="New value (as text)"/>
            <result type="text" description="'ok' or 'error: …'"/>
        </command>

    </suite>
</dictionary>

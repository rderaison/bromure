/* Reboot */
"Reboot “%@”?" = "Redémarrer « %@ » ?";
"Soft reboot" = "Redémarrage progressif";
"Hard reboot" = "Redémarrage forcé";
"Soft reboot gracefully halts the VM (filesystems flush, services stop) and boots a fresh one in this window. Hard reboot tears down the VM immediately and starts a fresh one." = "Le redémarrage progressif arrête proprement la VM (vidage des systèmes de fichiers, arrêt des services) et en démarre une nouvelle dans cette fenêtre. Le redémarrage forcé détruit la VM immédiatement et en démarre une nouvelle.";

/* Guardrails */
"Guardrails" = "Garde-fous";
"Guardrails strips destructive operations from the protocols this agent speaks. It's enforced on the host — inside the proxy — so a misbehaving or compromised agent in the VM can't bypass it. Blocked calls return a hard error the agent sees." = "Les garde-fous retirent les opérations destructrices des protocoles que parle cet agent. L'application se fait côté hôte — dans le proxy — afin qu'un agent défaillant ou compromis dans la VM ne puisse pas les contourner. Les appels bloqués renvoient une erreur ferme que l'agent voit.";
"Databases" = "Bases de données";
"No database endpoints configured. Add MongoDB, ClickHouse, or Elasticsearch endpoints under Credentials to guard them here." = "Aucun point de terminaison de base de données configuré. Ajoutez des points de terminaison MongoDB, ClickHouse ou Elasticsearch sous Identifiants pour les protéger ici.";
"No kubeconfigs on this profile — add one under Credentials for this to take effect." = "Aucun kubeconfig sur ce profil — ajoutez-en un sous Identifiants pour que cela prenne effet.";
"No registries on this profile — add one under Credentials for this to take effect." = "Aucun registre sur ce profil — ajoutez-en un sous Identifiants pour que cela prenne effet.";
"Set this endpoint's host under Credentials for the guard to take effect." = "Définissez l'hôte de ce point de terminaison sous Identifiants pour que la protection prenne effet.";
"Off" = "Désactivé";
"Block destructive" = "Bloquer les destructions";
"Read-only" = "Lecture seule";
"No filtering." = "Aucun filtrage.";
"Block deletes/drops; allow creates and updates." = "Bloque les suppressions/drops ; autorise les créations et mises à jour.";
"Block every change; reads only." = "Bloque toute modification ; lecture seule.";

"Enable automation server" = "Activar servidor de automatización";
"Listening on %@:%@. Toggling this off stops the server immediately; the MCP subcommand will no longer reach the app." = "Escuchando en %@:%@. Desactivarlo detiene el servidor de inmediato; el subcomando MCP ya no podrá comunicarse con la app.";
"Off — the HTTP API and the MCP subcommand are unavailable." = "Apagado — la API HTTP y el subcomando MCP no están disponibles.";
"Port" = "Puerto";

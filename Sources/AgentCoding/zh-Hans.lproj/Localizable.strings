"Docker registries" = "Docker 镜像仓库";
"deleteOne/deleteMany = destructive; insert/update/replace = write; find/aggregate = read." = "deleteOne/deleteMany = 破坏性；insert/update/replace = 写入；find/aggregate = 读取。";
"DROP/TRUNCATE/DELETE and ALTER…DELETE = destructive; INSERT/CREATE = write; SELECT/SHOW = read." = "DROP/TRUNCATE/DELETE 和 ALTER…DELETE = 破坏性；INSERT/CREATE = 写入；SELECT/SHOW = 读取。";

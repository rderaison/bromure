<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required to use Virtualization.framework APIs -->
    <key>com.apple.security.virtualization</key>
    <true/>
    <key>com.apple.application-identifier</key>
    <string>W3RD8G85BC.io.bromure.agentic-coding</string>
    <key>com.apple.developer.team-identifier</key>
    <string>W3RD8G85BC</string>
    <!-- Data-protection keychain access group (team-prefixed; self-authorized
         by the Developer ID cert). Without this the DPKC has no group to grant,
         so SecItemAdd/Copy fail with errSecMissingEntitlement and at-rest
         encryption (trace bodies, captured Claude credentials) silently fails,
         forcing the file-key fallback. -->
    <key>keychain-access-groups</key>
    <array>
        <string>W3RD8G85BC.io.bromure.agentic-coding</string>
    </array>
    <!-- vmnet framework for host-side network filtering -->
    <key>com.apple.developer.networking.vmnet</key>
    <true/>
    <!-- Local inference (vLLM.md §3.1): the on-demand vllm-mlx venv lives in
         Application Support, outside the app signature. Allow the hardened
         host process to dlopen its unsigned dylibs, and allow MLX's Metal
         JIT to map executable memory. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>

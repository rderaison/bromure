"Name" = "\U540d\U79f0";
"Comments" = "\U5907\U6ce8";
"A short note about this profile. Shown when you hover over it in the profile list." = "\U5173\U4e8e\U6b64\U914d\U7f6e\U6587\U4ef6\U7684\U7b80\U77ed\U8bf4\U660e\U3002\U5c06\U9f20\U6807\U60ac\U505c\U5728\U914d\U7f6e\U6587\U4ef6\U5217\U8868\U4e2d\U7684\U6761\U76ee\U4e0a\U65f6\U4f1a\U663e\U793a\U3002";

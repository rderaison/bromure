"Home Page" = "\U4e3b\U9875";
"The website that opens when you launch this profile." = "\U542f\U52a8\U6b64\U914d\U7f6e\U6587\U4ef6\U65f6\U6253\U5f00\U7684\U7f51\U7ad9\U3002";
"Language" = "语言";
"The language used by the browser. \U201CSame as System\U201D follows your Mac\U2019s language. Choosing a specific language reduces browser fingerprinting." = "浏览器使用的语言。\U201C与系统相同\U201D会跟随您 Mac 的语言。选择特定语言可减少浏览器指纹识别。";
"Retain Browsing Data" = "\U4fdd\U7559\U6d4f\U89c8\U6570\U636e";
"Keep your bookmarks, history, cookies, and passwords between sessions. When turned off, everything is erased each time you close the browser." = "\U5728\U591a\U6b21\U4f1a\U8bdd\U4e4b\U95f4\U4fdd\U7559\U4e66\U7b7e\U3001\U5386\U53f2\U8bb0\U5f55\U3001Cookie \U548c\U5bc6\U7801\U3002\U5173\U95ed\U540e\Uff0c\U6bcf\U6b21\U5173\U95ed\U6d4f\U89c8\U5668\U65f6\U6240\U6709\U6570\U636e\U90fd\U4f1a\U88ab\U6e05\U9664\U3002";

/* ProfileSettingsView — Performance */
"Control how the browser uses your Mac\U2019s hardware" = "\U63a7\U5236\U6d4f\U89c8\U5668\U5982\U4f55\U4f7f\U7528 Mac \U7684\U786c\U4ef6";
"GPU Acceleration" = "GPU \U52a0\U901f";
"Uses your Mac\U2019s graphics chip to make web pages render faster. Turn this off if you notice visual glitches or display problems." = "\U4f7f\U7528 Mac \U7684\U56fe\U5f62\U82af\U7247\U52a0\U5feb\U7f51\U9875\U6e32\U67d3\U901f\U5ea6\U3002\U5982\U679c\U4f60\U6ce8\U610f\U5230\U753b\U9762\U5f02\U5e38\U6216\U663e\U793a\U95ee\U9898\Uff0c\U8bf7\U5173\U95ed\U6b64\U9009\U9879\U3002";
"WebGL" = "WebGL";
"Lets websites display 3D graphics and interactive content. Required by some games, maps, and data visualizations." = "\U5141\U8bb8\U7f51\U7ad9\U663e\U793a 3D \U56fe\U5f62\U548c\U4ea4\U4e92\U5f0f\U5185\U5bb9\U3002\U67d0\U4e9b\U6e38\U620f\U3001\U5730\U56fe\U548c\U6570\U636e\U53ef\U89c6\U5316\U9700\U8981\U6b64\U529f\U80fd\U3002";

/* ProfileSettingsView — Media */
"Audio and device sharing" = "\U97f3\U9891\U548c\U8bbe\U5907\U5171\U4eab";
"Audio" = "\U97f3\U9891";
"Play sounds, music, and video audio from websites." = "\U64ad\U653e\U7f51\U7ad9\U4e2d\U7684\U58f0\U97f3\U3001\U97f3\U4e50\U548c\U89c6\U9891\U97f3\U9891\U3002";
"Volume" = "\U97f3\U91cf";
"Share Webcam" = "\U5171\U4eab\U6444\U50cf\U5934";
"Let websites in this browser access your Mac\U2019s camera for video calls and meetings." = "\U5141\U8bb8\U6b64\U6d4f\U89c8\U5668\U4e2d\U7684\U7f51\U7ad9\U8bbf\U95ee Mac \U7684\U6444\U50cf\U5934\Uff0c\U7528\U4e8e\U89c6\U9891\U901a\U8bdd\U548c\U4f1a\U8bae\U3002";
"Share Microphone" = "\U5171\U4eab\U9ea6\U514b\U98ce";
"Let websites in this browser access your Mac\U2019s microphone for calls and voice input." = "\U5141\U8bb8\U6b64\U6d4f\U89c8\U5668\U4e2d\U7684\U7f51\U7ad9\U8bbf\U95ee Mac \U7684\U9ea6\U514b\U98ce\Uff0c\U7528\U4e8e\U901a\U8bdd\U548c\U8bed\U97f3\U8f93\U5165\U3002";
"Device Selection" = "\U8bbe\U5907\U9009\U62e9";
"Choose which camera, microphone, and speaker to use with this profile." = "\U9009\U62e9\U8981\U4e0e\U6b64\U914d\U7f6e\U6587\U4ef6\U642d\U914d\U4f7f\U7528\U7684\U6444\U50cf\U5934\U3001\U9ea6\U514b\U98ce\U548c\U626c\U58f0\U5668\U3002";
"Speaker" = "\U626c\U58f0\U5668";
"Choose which speaker to use for audio output." = "\U9009\U62e9\U7528\U4e8e\U97f3\U9891\U8f93\U51fa\U7684\U626c\U58f0\U5668\U3002";
"Default" = "\U9ed8\U8ba4";

/* ProfileSettingsView — File Transfer */
"Control file uploads and downloads between your Mac and this browser" = "\U7ba1\U7406 Mac \U4e0e\U6b64\U6d4f\U89c8\U5668\U4e4b\U95f4\U7684\U6587\U4ef6\U4e0a\U4f20\U548c\U4e0b\U8f7d";

/* ProfileSettingsView — Privacy & Safety */
"Control what this browser can access and share" = "\U63a7\U5236\U6b64\U6d4f\U89c8\U5668\U53ef\U4ee5\U8bbf\U95ee\U548c\U5171\U4eab\U7684\U5185\U5bb9";
"Shared Clipboard" = "\U5171\U4eab\U526a\U8d34\U677f";
"Copy and paste text and images between your Mac and this browser. When turned off, the browser\U2019s clipboard is completely isolated." = "\U5728 Mac \U548c\U6b64\U6d4f\U89c8\U5668\U4e4b\U95f4\U590d\U5236\U548c\U7c98\U8d34\U6587\U672c\U53ca\U56fe\U7247\U3002\U5173\U95ed\U540e\Uff0c\U6d4f\U89c8\U5668\U7684\U526a\U8d34\U677f\U5c06\U5b8c\U5168\U9694\U79bb\U3002";
"File Upload" = "\U6587\U4ef6\U4e0a\U4f20";
"Allow sending files from your Mac to websites in this browser." = "\U5141\U8bb8\U5c06 Mac \U4e2d\U7684\U6587\U4ef6\U53d1\U9001\U5230\U6b64\U6d4f\U89c8\U5668\U4e2d\U7684\U7f51\U7ad9\U3002";
"File Download" = "\U6587\U4ef6\U4e0b\U8f7d";
"Allow saving files from websites to your Mac." = "\U5141\U8bb8\U5c06\U7f51\U7ad9\U4e2d\U7684\U6587\U4ef6\U4fdd\U5b58\U5230 Mac\U3002";
"Scan Downloads with VirusTotal" = "\U4f7f\U7528 VirusTotal \U626b\U63cf\U4e0b\U8f7d\U6587\U4ef6";
"Automatically check downloaded files for viruses and malware before they reach your Mac." = "\U5728\U4e0b\U8f7d\U6587\U4ef6\U5230\U8fbe Mac \U4e4b\U524d\Uff0c\U81ea\U52a8\U68c0\U67e5\U662f\U5426\U5b58\U5728\U75c5\U6bd2\U548c\U6076\U610f\U8f6f\U4ef6\U3002";
"VirusTotal API Key" = "VirusTotal API \U5bc6\U94a5";
"Block Threats" = "\U62e6\U622a\U5a01\U80c1";
"Automatically block files that VirusTotal identifies as malicious. Blocked files cannot be saved or dragged to your Mac." = "\U81ea\U52a8\U62e6\U622a VirusTotal \U8bc6\U522b\U4e3a\U6076\U610f\U7684\U6587\U4ef6\U3002\U88ab\U62e6\U622a\U7684\U6587\U4ef6\U65e0\U6cd5\U4fdd\U5b58\U6216\U62d6\U62fd\U5230 Mac\U3002";
"Block Unscannable Files" = "\U62e6\U622a\U65e0\U6cd5\U626b\U63cf\U7684\U6587\U4ef6";
"Block files that could not be scanned by VirusTotal (too large, rate-limited, or unknown). When turned off, unscannable files can still be saved manually." = "\U62e6\U622a VirusTotal \U65e0\U6cd5\U626b\U63cf\U7684\U6587\U4ef6\Uff08\U6587\U4ef6\U8fc7\U5927\U3001\U8bf7\U6c42\U9891\U7387\U53d7\U9650\U6216\U672a\U77e5\U6587\U4ef6\Uff09\U3002\U5173\U95ed\U540e\Uff0c\U65e0\U6cd5\U626b\U63cf\U7684\U6587\U4ef6\U4ecd\U53ef\U624b\U52a8\U4fdd\U5b58\U3002";
"Block Malware Sites" = "\U62e6\U622a\U6076\U610f\U7f51\U7ad9";
"Blocks access to websites known to distribute viruses or steal information, using Cloudflare\U2019s security DNS." = "\U4f7f\U7528 Cloudflare \U7684\U5b89\U5168 DNS \U62e6\U622a\U5df2\U77e5\U4f20\U64ad\U75c5\U6bd2\U6216\U7a83\U53d6\U4fe1\U606f\U7684\U7f51\U7ad9\U3002";
"Phishing Warning" = "\U9493\U9c7c\U8b66\U544a";
"Shows a warning when you\U2019re about to enter a password on a website that looks suspicious or fake." = "\U5f53\U4f60\U5373\U5c06\U5728\U770b\U8d77\U6765\U53ef\U7591\U6216\U4eff\U5192\U7684\U7f51\U7ad9\U4e0a\U8f93\U5165\U5bc6\U7801\U65f6\U663e\U793a\U8b66\U544a\U3002";
"Beta" = "Beta";
"Send Link to Other Session" = "\U5c06\U94fe\U63a5\U53d1\U9001\U5230\U5176\U4ed6\U4f1a\U8bdd";
"Adds a right-click menu option to send a web page link to another Bromure profile." = "\U5728\U53f3\U952e\U83dc\U5355\U4e2d\U6dfb\U52a0\U5c06\U7f51\U9875\U94fe\U63a5\U53d1\U9001\U5230\U5176\U4ed6 Bromure \U914d\U7f6e\U6587\U4ef6\U7684\U9009\U9879\U3002";

/* ProfileSettingsView — Network Isolation */
"Restrict which networks and ports this browser can reach" = "\U9650\U5236\U6b64\U6d4f\U89c8\U5668\U53ef\U8bbf\U95ee\U7684\U7f51\U7edc\U548c\U7aef\U53e3";
"Isolate from Local Network" = "\U4e0e\U672c\U5730\U7f51\U7edc\U9694\U79bb";
"Prevents this browser from reaching devices on your home or office network, like printers, NAS drives, or internal servers. Internet access is not affected." = "\U963b\U6b62\U6b64\U6d4f\U89c8\U5668\U8bbf\U95ee\U4f60\U5bb6\U5ead\U6216\U529e\U516c\U7f51\U7edc\U4e0a\U7684\U8bbe\U5907\Uff0c\U5982\U6253\U5370\U673a\U3001NAS \U5b58\U50a8\U6216\U5185\U90e8\U670d\U52a1\U5668\U3002\U4e92\U8054\U7f51\U8bbf\U95ee\U4e0d\U53d7\U5f71\U54cd\U3002";
"Restrict Outgoing Ports" = "\U9650\U5236\U51fa\U7ad9\U7aef\U53e3";
"Only allow the browser to connect on specific network ports. Useful for locking down which services the browser can reach." = "\U4ec5\U5141\U8bb8\U6d4f\U89c8\U5668\U901a\U8fc7\U7279\U5b9a\U7f51\U7edc\U7aef\U53e3\U8fde\U63a5\U3002\U53ef\U7528\U4e8e\U9650\U5236\U6d4f\U89c8\U5668\U53ef\U8bbf\U95ee\U7684\U670d\U52a1\U3002";
"Allowed ports (e.g. 80, 443, 8000-9000)" = "\U5141\U8bb8\U7684\U7aef\U53e3\Uff08\U4f8b\U5982 80, 443, 8000-9000\Uff09";
"DNS (port 53) is always allowed. Separate ports with commas. Use a dash for ranges." = "DNS\Uff08\U7aef\U53e3 53\Uff09\U59cb\U7ec8\U5141\U8bb8\U3002\U7528\U9017\U53f7\U5206\U9694\U7aef\U53e3\Uff0c\U7528\U77ed\U6a2a\U7ebf\U8868\U793a\U8303\U56f4\U3002";

/* ProfileSettingsView — VPN & Ads */
"Network privacy and ad blocking" = "\U7f51\U7edc\U9690\U79c1\U548c\U5e7f\U544a\U62e6\U622a";
"Cloudflare WARP" = "Cloudflare WARP";
"Routes all browser traffic through Cloudflare\U2019s encrypted network, hiding your IP address from websites. Works like a VPN." = "\U5c06\U6240\U6709\U6d4f\U89c8\U5668\U6d41\U91cf\U901a\U8fc7 Cloudflare \U7684\U52a0\U5bc6\U7f51\U7edc\U8def\U7531\Uff0c\U5bf9\U7f51\U7ad9\U9690\U85cf\U4f60\U7684 IP \U5730\U5740\U3002\U5de5\U4f5c\U539f\U7406\U7c7b\U4f3c VPN\U3002";
"No VPN" = "\U65E0 VPN";
"WireGuard" = "WireGuard";
"Choose a VPN to route browser traffic through an encrypted tunnel, hiding your IP address from websites." = "\U9009\U62E9 VPN \U5C06\U6D4F\U89C8\U5668\U6D41\U91CF\U901A\U8FC7\U52A0\U5BC6\U96A7\U9053\U8DEF\U7531\uFF0C\u5BF9\u7F51\u7AD9\u9690\u85CF\u4F60\u7684 IP \u5730\u5740\u3002";
"WireGuard Configuration" = "WireGuard \U914D\U7F6E";
"Paste your WireGuard .conf file below, or use the import button to load it from disk." = "\U5728\U4E0B\U65B9\U7C98\U8D34\U4F60\U7684 WireGuard .conf \U6587\U4EF6\uFF0C\u6216\u4F7F\u7528\u5BFC\u5165\u6309\u94AE\u4ECE\u78C1\u76D8\u52A0\u8F7D\u3002";
"Import .conf File\U2026" = "\U5BFC\U5165 .conf \U6587\U4EF6\U2026";
"Block Ads" = "\U62e6\U622a\U5e7f\U544a";
"Blocks ads and tracking scripts from loading on websites. This can make pages load faster and protects your privacy." = "\U963b\U6b62\U7f51\U7ad9\U52a0\U8f7d\U5e7f\U544a\U548c\U8ddf\U8e2a\U811a\U672c\U3002\U8fd9\U53ef\U4ee5\U52a0\U5feb\U9875\U9762\U52a0\U8f7d\U901f\U5ea6\U5e76\U4fdd\U62a4\U4f60\U7684\U9690\U79c1\U3002";

/* ProfileSettingsView — Enterprise */
"Settings for managed environments" = "\U9002\U7528\U4e8e\U53d7\U7ba1\U7406\U73af\U5883\U7684\U8bbe\U7f6e";
"Root Certificates" = "\U6839\U8bc1\U4e66";
"Install custom root CA certificates so the browser trusts your organization\U2019s internal websites and services. Accepts PEM, DER, CRT, and CER files." = "\U5b89\U88c5\U81ea\U5b9a\U4e49\U6839 CA \U8bc1\U4e66\Uff0c\U4ee5\U4fbf\U6d4f\U89c8\U5668\U4fe1\U4efb\U4f60\U7ec4\U7ec7\U7684\U5185\U90e8\U7f51\U7ad9\U548c\U670d\U52a1\U3002\U652f\U6301 PEM\U3001DER\U3001CRT \U548c CER \U6587\U4ef6\U3002";
"Add Certificate\U2026" = "\U6dfb\U52a0\U8bc1\U4e66\U2026";

/* ProfileSettingsView — Advanced */
"Additional options for power users" = "\U9762\U5411\U9ad8\U7ea7\U7528\U6237\U7684\U9644\U52a0\U9009\U9879";
"Encrypt Browsing Data" = "\U52a0\U5bc6\U6d4f\U89c8\U6570\U636e";

"WireGuard Configuration" = "WireGuard \U8A2D\U5B9A";
"Paste your WireGuard .conf file below, or use the import button to load it from disk." = "WireGuard \U306E .conf \U30D5\U30A1\U30A4\U30EB\U3092\U4E0B\U306B\U8CBC\U308A\U4ED8\U3051\U308B\U304B\U3001\U30A4\U30F3\U30DD\U30FC\U30C8\U30DC\U30BF\U30F3\U3092\U4F7F\U7528\U3057\U3066\U30C7\U30A3\U30B9\U30AF\U304B\U3089\U8AAD\U307F\U8FBC\U307F\U307E\U3059\U3002";
"Import .conf File\U2026" = ".conf \U30D5\U30A1\U30A4\U30EB\U3092\U8AAD\U307F\U8FBC\U3080\U2026";
"Block Ads" = "広告をブロック";
"Blocks ads and tracking scripts from loading on websites. This can make pages load faster and protects your privacy." = "Webサイト上の広告やトラッキングスクリプトの読み込みをブロックします。ページの読み込みが高速になり、プライバシーが保護されます。";

/* ProfileSettingsView — Enterprise */
"Settings for managed environments" = "管理環境向けの設定";
"Root Certificates" = "ルート証明書";
"Install custom root CA certificates so the browser trusts your organization\U2019s internal websites and services. Accepts PEM, DER, CRT, and CER files." = "カスタムルートCA証明書をインストールして、組織の内部Webサイトやサービスをブラウザが信頼できるようにします。PEM、DER、CRT、CERファイルに対応しています。";
"Add Certificate\U2026" = "証明書を追加\U2026";

/* ProfileSettingsView — Advanced */
"Additional options for power users" = "上級ユーザー向けの追加オプション";
"Encrypt Browsing Data" = "ブラウジングデータを暗号化";
"Encrypts all saved browsing data on your Mac\U2019s disk using LUKS. The encryption key is stored securely in your macOS Keychain. If you lose the key, your data cannot be recovered." = "LUKSを使用して、Mac上に保存されたすべてのブラウジングデータを暗号化します。暗号化キーはmacOSキーチェーンに安全に保管されます。キーを紛失した場合、データを復元することはできません。";
"Encryption" = "暗号化";
"Turn on \U201CRetain Browsing Data\U201D in General to access disk encryption options." = "ディスク暗号化オプションにアクセスするには、「一般」で\U201Cブラウジングデータを保持\U201Dをオンにしてください。";


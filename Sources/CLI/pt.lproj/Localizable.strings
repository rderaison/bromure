"Add Certificate\U2026" = "Adicionar Certificado\U2026";

/* ProfileSettingsView — Advanced */
"Additional options for power users" = "Opções adicionais para usuários avançados";
"Encrypt Browsing Data" = "Criptografar Dados de Navegação";

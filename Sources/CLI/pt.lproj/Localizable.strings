/* ProfileSettingsView — Privacy & Safety */
"Control what this browser can access and share" = "Controle o que este navegador pode acessar e compartilhar";
"Shared Clipboard" = "Área de Transferência Compartilhada";
"Copy and paste text and images between your Mac and this browser. When turned off, the browser\U2019s clipboard is completely isolated." = "Copie e cole texto e imagens entre o seu Mac e este navegador. Quando desativado, a área de transferência do navegador fica completamente isolada.";
"File Upload" = "Envio de Arquivos";
"Allow sending files from your Mac to websites in this browser." = "Permita enviar arquivos do seu Mac para sites neste navegador.";
"File Download" = "Download de Arquivos";
"Allow saving files from websites to your Mac." = "Permita salvar arquivos de sites no seu Mac.";
"Scan Downloads with VirusTotal" = "Verificar Downloads com o VirusTotal";
"Automatically check downloaded files for viruses and malware before they reach your Mac." = "Verifique automaticamente se os arquivos baixados contêm vírus e malware antes de chegarem ao seu Mac.";
"VirusTotal API Key" = "Chave de API do VirusTotal";
"Block Threats" = "Bloquear Ameaças";

"Import .conf File\U2026" = "Importer un fichier .conf\U2026";
"Block Ads" = "Bloquer les publicit\U00E9s";
"Blocks ads and tracking scripts from loading on websites. This can make pages load faster and protects your privacy." = "Bloque le chargement des publicit\U00E9s et des scripts de suivi sur les sites web. Cela peut acc\U00E9l\U00E9rer le chargement des pages et prot\U00E9ger votre vie priv\U00E9e.";

/* ProfileSettingsView — Enterprise */
"Settings for managed environments" = "R\U00E9glages pour les environnements g\U00E9r\U00E9s";

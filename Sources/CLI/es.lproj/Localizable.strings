"File Download" = "Descargar archivos";
"Allow saving files from websites to your Mac." = "Permite guardar archivos de sitios web en su Mac.";
"Scan Downloads with VirusTotal" = "Analizar descargas con VirusTotal";
"Automatically check downloaded files for viruses and malware before they reach your Mac." = "Verifica autom\U00E1ticamente los archivos descargados en busca de virus y software malicioso antes de que lleguen a su Mac.";
"VirusTotal API Key" = "Clave de API de VirusTotal";
"Block Threats" = "Bloquear amenazas";

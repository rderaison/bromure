#!/bin/sh
# Cursor size and display scale are set after chrome-env is loaded (runtime, not build-time)
export XCURSOR_THEME=Adwaita

/usr/local/bin/resize-watcher.sh &
openbox &

# XDG_RUNTIME_DIR is required by PipeWire and other session services.
export XDG_RUNTIME_DIR="/run/user/$(id -u)"
doas mkdir -p "$XDG_RUNTIME_DIR"
doas chown $(id -u):$(id -g) "$XDG_RUNTIME_DIR"

# Start D-Bus session bus (dbus-x11 provides dbus-launch)
eval $(dbus-launch --sh-syntax)

# Wait for the host to write chrome-ready (up to 120s).
# The host writes it when the user selects a profile and opens a browser.
# Use a loop to avoid two races:
#   1. /tmp/bromure may not exist yet (created by on-boot.sh / config-agent) —
#      inotifywait would fail silently and xinitrc would skip the wait entirely.
#   2. TOCTOU: chrome-ready could be created between the [ -f ] check and
#      inotifywait starting, causing inotifywait to miss the event.
# Wait indefinitely for the host to write chrome-ready.
# Pre-warmed VMs can sit idle for hours — this MUST NOT time out.
mkdir -p /tmp/bromure
while [ ! -f /tmp/bromure/chrome-ready ]; do
    inotifywait -e create --include "chrome-ready" /tmp/bromure/ 2>/dev/null || sleep 1
done
EXTRA_FLAGS=
CHROME_URL=
SWAP_CMD_CTRL=
CLIPBOARD=
KEYCHAIN=
AUTOMATION=
NATIVE_CHROME=
DEBUG_SHELL=
MICROPHONE=
AUDIO=
AUDIO_VOLUME=
PROFILE_DIR=
CHROME_LANG=
DISPLAY_SCALE=
MTU=
KEY_REPEAT_DELAY_MS=
KEY_REPEAT_RATE_HZ=
[ -f /tmp/bromure/chrome-env ] && . /tmp/bromure/chrome-env

# MTU clamp on the default-route interface. Default 1400 covers most
# VPNs (WireGuard ~1420, IKEv2 ~1400). Override on the host via:
#   defaults write io.bromure.app vm.mtu -int <value>
[ -z "$MTU" ] && MTU=1400
NIC=$(ip route show default 2>/dev/null | awk '/default/ {print $5; exit}')
[ -n "$NIC" ] && doas ip link set dev "$NIC" mtu "$MTU" 2>/dev/null
echo "xinitrc: ${NIC:-<no-default-route>} mtu=$MTU" > /dev/hvc0

# Key-repeat: match macOS's InitialKeyRepeat + KeyRepeat so typing in
# Chromium feels the same as typing in Safari on the host.
if [ -n "$KEY_REPEAT_DELAY_MS" ] && [ -n "$KEY_REPEAT_RATE_HZ" ]; then
    xset r rate "$KEY_REPEAT_DELAY_MS" "$KEY_REPEAT_RATE_HZ" 2>/dev/null
fi

# Set cursor size and display scale from runtime config (not build-time template)
DISPLAY_SCALE="${DISPLAY_SCALE:-2}"
CURSOR_SIZE=$((DISPLAY_SCALE * 24))
export XCURSOR_SIZE="$CURSOR_SIZE"
echo "Xcursor.size: $CURSOR_SIZE" | xrdb -merge

# Wait for persistent profile directory to be fully mounted before starting Chrome.
if [ -n "$PROFILE_DIR" ]; then
    for i in $(seq 1 100); do
        [ -d "$PROFILE_DIR/lost+found" ] && break
        sleep 0.1
    done
fi

# Start PipeWire + WirePlumber only when audio is enabled for this profile.
if [ "$AUDIO" = "1" ]; then
    pipewire &
    sleep 0.3
    wireplumber &
    pipewire-pulse &
    sleep 0.5
    [ -n "$AUDIO_VOLUME" ] && pactl set-sink-volume @DEFAULT_SINK@ "${AUDIO_VOLUME}%" &
fi

[ "$CLIPBOARD" = "1" ] && spice-vdagent -x 2>/dev/null &
# file-agent.py and webcam-agent.py are started at boot via inittab
[ "$SWAP_CMD_CTRL" = "1" ] && setxkbmap -option ctrl:swap_lwin_lctl,ctrl:swap_rctl
[ "$MICROPHONE" = "1" ] && pactl load-module module-alsa-source device=hw:0,1 source_name=virtio_mic source_properties=device.description=Microphone 2>/dev/null &
[ "$AUTOMATION" = "1" ] && /usr/local/bin/resilient-launch.sh /usr/local/bin/cdp-agent.py &
[ "$NATIVE_CHROME" = "1" ] && /usr/local/bin/resilient-launch.sh /usr/local/bin/tab-agent.py &
[ "$DEBUG_SHELL" = "1" ] && /usr/local/bin/resilient-launch.sh /usr/local/bin/shell-agent.py &
echo "xinitrc: EXTRA_FLAGS=$EXTRA_FLAGS CHROME_URL=$CHROME_URL SWAP_CMD_CTRL=$SWAP_CMD_CTRL" > /dev/hvc0
export LIBGL_ALWAYS_SOFTWARE=1


# Boost Xorg and Chromium to high CPU priority (-10 nice).
# Xorg is already running; renice it now, then renice Chrome once it starts.
doas renice -10 $(pgrep -f /usr/libexec/Xorg) 2>/dev/null
(sleep 1; for pid in $(pgrep -f chromium-browser); do doas renice -10 $pid 2>/dev/null; done) &

if [ "$TEST_SUITE" = "1" ]; then
    /usr/local/bin/test-runner.sh
    doas poweroff
    exit 0
fi

LANG_FLAG=
[ -n "$CHROME_LANG" ] && LANG_FLAG="--lang=$CHROME_LANG"

# Native-chrome mode hides Chromium's tab strip + omnibox on the *macOS*
# side: the VZ scanout is configured taller than the visible window content
# and the host clips off the top rows. Chromium itself runs completely
# unmodified — same launch flags, same maximize behaviour, same window
# manager rules. tab-agent + the native titlebar handle the visible UI.
CHROME_CMD="chromium-browser --no-first-run --start-maximized --force-device-scale-factor=$DISPLAY_SCALE --disable-vulkan --font-render-hinting=none $LANG_FLAG $EXTRA_FLAGS $CHROME_URL"

# VPN splash: when a VPN is configured to connect at startup, the tunnel
# takes a few seconds to establish. Loading the user's URL in that window
# would leak the real IP. Block Chrome behind a local splash page until
# the VPN agent signals via /tmp/bromure/vpn-status.
if [ -n "$VPN_AUTO_CONNECT" ]; then
    echo "xinitrc: VPN auto-connect ($VPN_AUTO_CONNECT) — gating Chrome on tunnel" > /dev/hvc0

    SPLASH_PID=
    if [ -f /opt/bromure/splash/splash.html ]; then
        SPLASH_LANG="${CHROME_LANG:-en}"
        chromium-browser \
            --kiosk \
            --app="file:///opt/bromure/splash/splash.html?lang=$SPLASH_LANG" \
            --user-data-dir=/tmp/bromure/splash-profile \
            --no-proxy-server \
            --allow-file-access-from-files \
            --no-first-run \
            --disable-background-networking \
            --disable-component-update \
            --disable-default-apps \
            --disable-sync \
            --disable-features=Translate,LcdText \
            --font-render-hinting=none \
            --force-device-scale-factor="$DISPLAY_SCALE" \
            >/dev/null 2>&1 &
        SPLASH_PID=$!
    fi

    # Wait up to 120s for the VPN agent to write a status. WireGuard/IKEv2
    # complete in seconds; WARP registration + handshake can take ~30s.
    for _ in $(seq 1 120); do
        [ -f /tmp/bromure/vpn-status ] && break
        sleep 1
    done

    if [ ! -f /tmp/bromure/vpn-status ]; then
        # Agent never wrote a status — synthesize a timeout so the splash
        # shows *something* instead of spinning forever.
        printf 'error\nVPN connection timed out after 120s. The VPN agent did not respond.\n' > /tmp/bromure/vpn-status
    fi

    VPN_STATUS=$(head -n 1 /tmp/bromure/vpn-status 2>/dev/null)
    echo "xinitrc: VPN status = $VPN_STATUS" > /dev/hvc0

    if [ "$VPN_STATUS" = "ok" ]; then
        # Tunnel is up — kill splash and proceed to Chrome.
        if [ -n "$SPLASH_PID" ]; then
            kill "$SPLASH_PID" 2>/dev/null
            wait "$SPLASH_PID" 2>/dev/null
        fi
    else
        # Tunnel failed. The splash has already rendered the error.
        # Wait for the user to close that window, then end the session
        # WITHOUT launching Chrome (launching now would leak the IP).
        if [ -n "$SPLASH_PID" ]; then
            wait "$SPLASH_PID"
        fi
        echo "xinitrc: VPN failed, skipping Chrome launch" > /dev/hvc0
        doas udhcpc -R -i eth0 2>/dev/null
        doas poweroff
        exit 0
    fi
fi

start_ts=$(date +%s)
prefs_backup=
for attempt in 1 2 3 4 5; do
    $CHROME_CMD
    now_ts=$(date +%s)
    elapsed=$((now_ts - start_ts))
    # If Chrome ran for more than 10 seconds, treat it as a real session
    [ "$elapsed" -gt 10 ] && break

    if [ "$attempt" -eq 3 ] && [ -n "$PROFILE_DIR" ] && [ -d "$PROFILE_DIR" ]; then
        # Chrome crashed 3 times quickly — suspect corrupt prefs; move them aside
        prefs_backup="disabled-prefs.$((now_ts % 3600))"
        mkdir -p "$PROFILE_DIR/$prefs_backup"
        cd "$PROFILE_DIR"
        for f in *; do
            [ "$f" = "$prefs_backup" ] && continue
            mv "$f" "$prefs_backup/" 2>/dev/null
        done
        echo "xinitrc: moved profile prefs aside to $prefs_backup (attempt $attempt)" > /dev/hvc0
    elif [ "$attempt" -eq 4 ] && [ -n "$prefs_backup" ] && [ -d "$PROFILE_DIR/$prefs_backup" ]; then
        # Still crashing without prefs — restore them
        cd "$PROFILE_DIR"
        mv "$prefs_backup"/* . 2>/dev/null
        rm -rf "$prefs_backup"
        prefs_backup=
        echo "xinitrc: restored profile prefs (attempt $attempt)" > /dev/hvc0
    fi
done

doas udhcpc -R -i eth0 2>/dev/null
doas poweroff


#!/bin/sh
export XCURSOR_SIZE=%%CURSOR_SIZE%%
export XCURSOR_THEME=Adwaita
echo "Xcursor.size: %%CURSOR_SIZE%%" | xrdb -merge

/usr/local/bin/resize-watcher.sh &
openbox &

# XDG_RUNTIME_DIR is required by PipeWire and other session services.
export XDG_RUNTIME_DIR="/run/user/$(id -u)"
doas mkdir -p "$XDG_RUNTIME_DIR"
doas chown $(id -u):$(id -g) "$XDG_RUNTIME_DIR"

# Start D-Bus session bus (dbus-x11 provides dbus-launch)
eval $(dbus-launch --sh-syntax)

# Wait for the host to write chrome-ready (up to 120s).
# The host writes it when the user selects a profile and opens a browser.
# Use a loop to avoid two races:
#   1. /tmp/bromure may not exist yet (created by on-boot.sh / config-agent) —
#      inotifywait would fail silently and xinitrc would skip the wait entirely.
#   2. TOCTOU: chrome-ready could be created between the [ -f ] check and
#      inotifywait starting, causing inotifywait to miss the event.
mkdir -p /tmp/bromure
for _attempt in $(seq 1 24); do
    [ -f /tmp/bromure/chrome-ready ] && break
    inotifywait -t 5 -e create --include "chrome-ready" /tmp/bromure/ 2>/dev/null || true
done
EXTRA_FLAGS=
CHROME_URL=
SWAP_CMD_CTRL=
CLIPBOARD=
AUTOMATION=
MICROPHONE=
AUDIO=
AUDIO_VOLUME=
PROFILE_DIR=
CHROME_LANG=
[ -f /tmp/bromure/chrome-env ] && . /tmp/bromure/chrome-env

# Wait for persistent profile directory to be fully mounted before starting Chrome.
if [ -n "$PROFILE_DIR" ]; then
    for i in $(seq 1 100); do
        [ -d "$PROFILE_DIR/lost+found" ] && break
        sleep 0.1
    done
fi

# Start PipeWire + WirePlumber only when audio is enabled for this profile.
if [ "$AUDIO" = "1" ]; then
    pipewire &
    sleep 0.3
    wireplumber &
    pipewire-pulse &
    sleep 0.5
    [ -n "$AUDIO_VOLUME" ] && pactl set-sink-volume @DEFAULT_SINK@ "${AUDIO_VOLUME}%" &
fi

[ "$CLIPBOARD" = "1" ] && spice-vdagent -x 2>/dev/null &
# file-agent.py and webcam-agent.py are started at boot via inittab
[ "$SWAP_CMD_CTRL" = "1" ] && setxkbmap -option ctrl:swap_lwin_lctl,ctrl:swap_rctl
[ "$MICROPHONE" = "1" ] && pactl load-module module-alsa-source device=hw:0,1 source_name=virtio_mic source_properties=device.description=Microphone 2>/dev/null &
[ "$AUTOMATION" = "1" ] && /usr/local/bin/cdp-agent.py &
echo "xinitrc: EXTRA_FLAGS=$EXTRA_FLAGS CHROME_URL=$CHROME_URL SWAP_CMD_CTRL=$SWAP_CMD_CTRL" > /dev/hvc0
export LIBGL_ALWAYS_SOFTWARE=1

# Boost Xorg and Chromium to high CPU priority (-10 nice).
# Xorg is already running; renice it now, then renice Chrome once it starts.
doas renice -10 $(pgrep -f /usr/libexec/Xorg) 2>/dev/null
(sleep 1; for pid in $(pgrep -f chromium-browser); do doas renice -10 $pid 2>/dev/null; done) &

if [ "$TEST_SUITE" = "1" ]; then
    /usr/local/bin/test-runner.sh
    doas poweroff
    exit 0
fi

LANG_FLAG=
[ -n "$CHROME_LANG" ] && LANG_FLAG="--lang=$CHROME_LANG"
chromium-browser --no-first-run --start-maximized --force-device-scale-factor=%%DISPLAY_SCALE%% --use-gl=angle --use-angle=gl --ignore-gpu-blocklist --enable-gpu-rasterization --enable-smooth-scrolling --enable-zero-copy --disable-vulkan $LANG_FLAG $EXTRA_FLAGS "$CHROME_URL"
doas poweroff


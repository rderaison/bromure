{
  "manifest_version": 3,
  "name": "Bromure File Picker",
  "version": "1.0.0",
  "description": "Intercepts file upload dialogs and routes them through the host file picker.",
  "key": "",
  "permissions": [
    "nativeMessaging",
    "debugger",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "storage": {
    "managed_schema": "schema.json"
  }
}

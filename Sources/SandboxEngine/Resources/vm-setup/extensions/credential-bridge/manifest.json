{
  "manifest_version": 3,
  "name": "Bromure Credential Bridge",
  "version": "1.0.0",
  "description": "Passkey and password bridge to macOS platform authenticator and Keychain.",
  "permissions": [
    "nativeMessaging"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-isolated.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}

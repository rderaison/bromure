{
  "manifest_version": 3,
  "name": "Bromure Trace",
  "version": "1.0.0",
  "description": "Captures web request telemetry and forwards it to the host for session tracing.",
  "key": "",
  "permissions": [
    "webRequest",
    "webNavigation",
    "nativeMessaging",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["form-capture.js"],
    "run_at": "document_idle",
    "all_frames": true
  }]
}

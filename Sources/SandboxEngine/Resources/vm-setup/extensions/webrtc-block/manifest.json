{
  "manifest_version": 3,
  "name": "Bromure WebRTC Block",
  "version": "1.0.0",
  "description": "Blocks WebRTC IP leak by overriding RTCPeerConnection.",
  "key": "",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["block.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}

{
  "manifest_version": 3,
  "name": "Bromure Corporate Guard",
  "version": "1.0.0",
  "description": "Gates non-corporate sites per managed-profile settings: either warns with a banner (tracing mode) or redirects to a private window (private-external mode).",
  "key": "",
  "permissions": ["storage", "tabs", "webNavigation", "nativeMessaging"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["common.js", "content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "storage": {
    "managed_schema": "schema.json"
  }
}

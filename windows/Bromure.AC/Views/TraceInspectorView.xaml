<UserControl x:Class="Bromure.AC.Views.TraceInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ChromeBackground}"
             Foreground="{StaticResource TextPrimary}">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Trace Inspector"
                   FontSize="22" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="0" Margin="0,30,0,0"
                   Foreground="{StaticResource TextSecondary}" FontSize="11">
            Live-tail of the MITM proxy. Each row is one HTTPS request
            decrypted by the host, with swap reports + leak warnings.
        </TextBlock>

        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Padding="8,6" Margin="0,0,8,0"
                     Background="{StaticResource PanelBackground}"
                     Foreground="{StaticResource TextPrimary}"
                     BorderThickness="1" BorderBrush="#33FFFFFF"
                     Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Filter by host or path"/>
            <!-- Audit 09: method + status filters alongside the host/path
                 substring filter. Status accepts 200, 4xx, etc. -->
            <TextBox Grid.Column="1" Padding="8,6" Margin="0,0,8,0"
                     Background="{StaticResource PanelBackground}"
                     Foreground="{StaticResource TextPrimary}"
                     BorderThickness="1" BorderBrush="#33FFFFFF"
                     Text="{Binding MethodFilter, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Method (GET, POST…)"/>
            <TextBox Grid.Column="2" Padding="8,6" Margin="0,0,8,0"
                     Background="{StaticResource PanelBackground}"
                     Foreground="{StaticResource TextPrimary}"
                     BorderThickness="1" BorderBrush="#33FFFFFF"
                     Text="{Binding StatusFilter, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Status (200, 4xx, 5xx)"/>
            <Button Grid.Column="3" Content="Refresh" Padding="14,6"
                    Background="{StaticResource AccentBrush}"
                    Foreground="{StaticResource TextPrimary}"
                    BorderThickness="0" Cursor="Hand"
                    Command="{Binding RefreshCommand}"/>
        </Grid>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Rows}" SelectedItem="{Binding Selected}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="{StaticResource PanelBackground}"
                  Foreground="{StaticResource TextPrimary}"
                  BorderThickness="0" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#22FFFFFF"
                  RowBackground="{StaticResource PanelBackground}"
                  AlternatingRowBackground="#11FFFFFF"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Width="110" Binding="{Binding TimestampLocal}"/>
                <DataGridTextColumn Header="Method" Width="70" Binding="{Binding Method}"/>
                <DataGridTextColumn Header="Host" Width="220" Binding="{Binding Host}"/>
                <DataGridTextColumn Header="Path" Width="*" Binding="{Binding Path}"/>
                <DataGridTextColumn Header="Status" Width="70" Binding="{Binding StatusLabel}"/>
                <DataGridTextColumn Header="Latency" Width="80" Binding="{Binding Latency}"/>
                <DataGridTextColumn Header="Swaps" Width="100" Binding="{Binding SwapsLabel}"/>
                <DataGridTextColumn Header="Leaks" Width="100" Binding="{Binding LeaksLabel}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Detail panel -->
        <Border Grid.Row="3" Background="{StaticResource PanelBackground}"
                CornerRadius="6" Padding="16" Margin="0,16,0,0"
                Visibility="{Binding Selected, Converter={StaticResource BoolToVis}}"
                DataContext="{Binding Selected}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding Record.Host}" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="{Binding Record.Path}" FontFamily="Consolas" FontSize="11"
                               Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>

                    <ItemsControl ItemsSource="{Binding Record.Swaps}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Header}" FontFamily="Consolas"
                                               Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock Grid.Column="1" FontFamily="Consolas">
                                        <Run Text="{Binding FakePreview, Mode=OneWay}" Foreground="#88B4F0"/>
                                        <Run Text=" → " Foreground="{StaticResource TextSecondary}"/>
                                        <Run Text="{Binding RealPreview, Mode=OneWay}" Foreground="#4CC990"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding Record.Leaks}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="Consolas"
                                           Foreground="{StaticResource DangerBrush}">
                                    <Run Text="⚠ "/>
                                    <Run Text="{Binding Header, Mode=OneWay}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding ValuePreview, Mode=OneWay}"/>
                                    <Run Text=" ("/>
                                    <Run Text="{Binding Suspicion, Mode=OneWay}"/>
                                    <Run Text=")"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Request + response body panes — newly added. Bodies are
             AES-GCM-encrypted at rest; the inspector decrypts on
             demand through the engine's Vault (passed at ctor). -->
        <Grid Grid.Row="4" Margin="0,16,0,0"
              Visibility="{Binding SelectedBodyStored, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBackground}"
                    CornerRadius="6" Padding="12" Margin="0,0,4,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Request body" FontWeight="SemiBold"/>
                        <Button Grid.Column="1" Content="Copy" Padding="6,2"
                                Command="{Binding CopyRequestBodyCommand}"/>
                    </Grid>
                    <TextBox Grid.Row="1" Text="{Binding SelectedRequestBody, Mode=OneWay}"
                             IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                             Background="Transparent" Foreground="{StaticResource TextPrimary}"
                             BorderThickness="0" TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True"/>
                </Grid>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource PanelBackground}"
                    CornerRadius="6" Padding="12" Margin="4,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Response body" FontWeight="SemiBold"/>
                        <Button Grid.Column="1" Content="Copy" Padding="6,2"
                                Command="{Binding CopyResponseBodyCommand}"/>
                    </Grid>
                    <TextBox Grid.Row="1" Text="{Binding SelectedResponseBody, Mode=OneWay}"
                             IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                             Background="Transparent" Foreground="{StaticResource TextPrimary}"
                             BorderThickness="0" TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<Window x:Class="Bromure.AC.Views.SessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Bromure AC"
        Width="1280" Height="800"
        Background="#0d1117"
        Foreground="{StaticResource TextPrimary}"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Manual"
        ResizeMode="CanResize">
    <!-- Custom title bar — Windows Terminal style. We draw the
         min/max/close buttons ourselves on the right; tabs +
         new-tab (+) sit in the draggable caption area. Caption
         clicks drag the window; tab + button clicks pass through
         via IsHitTestVisibleInChrome. -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="38"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid Background="#0d1117">
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Title bar: tabs (left, with + button after) | window controls (right) -->
        <Grid Grid.Row="0" Background="#0d1117">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Margin="8,4,0,0"
                        VerticalAlignment="Bottom"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel x:Name="TabStrip" Orientation="Horizontal"/>
                <Button x:Name="NewTabButton"
                        Content="+"
                        Click="OnNewTabClick"
                        Width="32" Height="32"
                        Margin="6,0,0,2"
                        Padding="0"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="#BFD0E6"
                        FontSize="18"
                        FontWeight="Light"
                        Cursor="Hand"
                        ToolTip="New tab (Ctrl+T)"
                        VerticalAlignment="Bottom"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Top"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <!-- Audit 10 §4.1: shared-folders popover. Lists the
                     active profile's mounted host paths; click a row
                     to jump to it in Explorer. Hidden when the profile
                     has no shared folders. -->
                <Button x:Name="SharesButton"
                        Click="OnSharesClick"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        Padding="8,4"
                        Background="#22FFFFFF"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        Foreground="#E6EDF3"
                        FontSize="11"
                        Cursor="Hand"
                        ToolTip="Shared folders">
                    <TextBlock x:Name="SharesButtonLabel" Text="📁 Shares"/>
                </Button>
                <Popup x:Name="SharesPopup"
                       PlacementTarget="{Binding ElementName=SharesButton}"
                       Placement="Bottom"
                       AllowsTransparency="True"
                       StaysOpen="False">
                    <Border Background="#1F2530" BorderBrush="#33FFFFFF"
                            BorderThickness="1" CornerRadius="6" Padding="6">
                        <ItemsControl x:Name="SharesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Tag="{Binding}"
                                            Click="OnSharesItemClick"
                                            HorizontalContentAlignment="Left"
                                            Padding="10,4"
                                            Background="Transparent"
                                            Foreground="#E6EDF3"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="12"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Popup>
                <!-- Audit 10 §4.1: reboot button. Confirmation dialog
                     before firing systemctl reboot inside the guest. -->
                <Button x:Name="RebootButton"
                        Click="OnRebootClick"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        Padding="8,4"
                        Background="#22FFFFFF"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        Foreground="#E6EDF3"
                        FontSize="11"
                        Cursor="Hand"
                        ToolTip="Reboot the guest VM">
                    <TextBlock Text="🔄 Reboot"/>
                </Button>
                <!-- Audit 10 §4.1: trace inspector quick-jump. Surfaces
                     the main window's Trace pane so the user can
                     correlate session activity with intercepted
                     exchanges without hunting through the menu. -->
                <Button x:Name="TraceButton"
                        Click="OnTraceButtonClick"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        Padding="8,4"
                        Background="#22FFFFFF"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        Foreground="#E6EDF3"
                        FontSize="11"
                        Cursor="Hand"
                        ToolTip="Open trace inspector">
                    <TextBlock Text="🔍 Trace"/>
                </Button>
                <!-- Audit 10 §4.1: IP chip. Shows the guest's current
                     LAN IP; click copies to clipboard (handy for
                     ssh / scp into the VM from another host shell).
                     Hidden until VmGuestIpAddress resolves; updated
                     live by the host's IP-refresh listener. -->
                <Button x:Name="IpChip"
                        Click="OnIpChipClick"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        Padding="10,4"
                        Background="#22FFFFFF"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        Foreground="#E6EDF3"
                        FontFamily="Cascadia Code, Consolas, monospace"
                        FontSize="11"
                        Cursor="Hand"
                        ToolTip="Click to copy guest IP"/>
                <Button x:Name="MinButton"
                        Click="OnMinClick"
                        Content="&#xE921;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="46" Height="38"
                        Background="Transparent"
                        Foreground="#E6EDF3"
                        BorderThickness="0"
                        FontSize="10"
                        ToolTip="Minimize"/>
                <Button x:Name="MaxButton"
                        Click="OnMaxClick"
                        Content="&#xE922;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="46" Height="38"
                        Background="Transparent"
                        Foreground="#E6EDF3"
                        BorderThickness="0"
                        FontSize="10"
                        ToolTip="Maximize"/>
                <Button x:Name="CloseButton"
                        Click="OnCloseClick"
                        Content="&#xE8BB;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="46" Height="38"
                        Background="Transparent"
                        Foreground="#E6EDF3"
                        BorderThickness="0"
                        FontSize="10"
                        ToolTip="Close"/>
            </StackPanel>
        </Grid>
        <ContentPresenter Grid.Row="1" x:Name="ActiveContent"/>
    </Grid>
</Window>

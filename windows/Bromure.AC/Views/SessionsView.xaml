<UserControl x:Class="Bromure.AC.Views.SessionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ChromeBackground}"
             Foreground="{StaticResource TextPrimary}">
    <!-- Profile picker — port of macOS ProfilePickerView. List of
         profiles, click row to launch a kitty session as a free WSLg
         window. + / - buttons add and remove. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header — app title block. -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,18,20,8">
            <Border Width="40" Height="40" CornerRadius="9"
                    Background="{StaticResource AccentBrush}" Margin="0,0,12,0">
                <TextBlock Text="b" Foreground="White" FontSize="22"
                           FontFamily="Segoe UI" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,-2,0,0"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Bromure Agentic Coding" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="Pick a profile to open a session"
                           FontSize="11" Foreground="{StaticResource TextSecondary}"/>
            </StackPanel>
        </StackPanel>

        <!-- Profile list. -->
        <Border Grid.Row="1" Margin="20,4,20,4" CornerRadius="8"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <ListBox ItemsSource="{Binding Rows}"
                         SelectedItem="{Binding Selected}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="8,4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <!-- UX #1: card-style rows. Default WPF
                                 ListBoxItem chrome looks like Win95.
                                 Custom template gives each profile a
                                 rounded card with subtle hover + a
                                 left accent stripe when selected. -->
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="card"
                                                Background="{StaticResource PanelElevated}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="0">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                <Setter TargetName="card" Property="Background" Value="{StaticResource HoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                <Setter TargetName="card" Property="BorderThickness" Value="1,1,1,1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- Audit 08 §2.4: per-row right-click menu.
                                 ContextMenu lives on the row's Border (not in
                                 ItemContainerStyle Setter) — Click handlers
                                 don't survive the XAML compiler's connection-ID
                                 generation when they live inside a Style.Setter
                                 template, causing a "MenuItem cannot cast to
                                 StackPanel" crash at view instantiation. -->
                            <Border Padding="18,16" BorderThickness="0">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Edit profile"
                                                  Command="{Binding EditCommand}"/>
                                        <MenuItem Header="Duplicate profile"
                                                  Click="OnDuplicateProfileClick"/>
                                        <Separator/>
                                        <MenuItem Header="View SSH public key"
                                                  Click="OnViewSshPublicKey"/>
                                        <Separator/>
                                        <MenuItem Header="Reset disk…"
                                                  Click="OnResetDiskClick"/>
                                        <Separator/>
                                        <MenuItem Header="Delete profile…"
                                                  Click="OnDeleteProfileClick"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- UX #1: bigger color dot (visual anchor)
                                         + brighter name. The dot doubles as the
                                         profile's identity so make it pop. -->
                                    <Ellipse Grid.Column="0" Width="14" Height="14"
                                             VerticalAlignment="Center"
                                             Fill="{Binding ColorBrush}"/>

                                    <!-- Name + subtitle -->
                                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="{StaticResource FontSizeTitle}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <Ellipse Width="7" Height="7" Margin="8,1,0,0"
                                                     Visibility="{Binding IsRunning,
                                                       Converter={StaticResource BoolToVis}}"
                                                     Fill="#34C759" VerticalAlignment="Center"/>
                                            <!-- Audit 08 §2.2: compromise badge. macOS shows
                                                 a red ⓘ next to compromised profiles in the
                                                 picker so the user can spot them before
                                                 attempting to launch. -->
                                            <TextBlock Text="⚠" FontSize="13" Margin="8,0,0,0"
                                                       Foreground="#FF4D4F" VerticalAlignment="Center"
                                                       ToolTip="A real credential was seen leaving this profile. The session disk will be wiped on next launch."
                                                       Visibility="{Binding IsCompromised,
                                                         Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding SubtitleText}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Margin="0,6,0,0"/>
                                        <TextBlock Text="{Binding StatusDetail}" FontSize="10"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Margin="0,2,0,0" TextWrapping="Wrap"
                                                   Visibility="{Binding StatusDetail,
                                                     Converter={StaticResource StringToVis},
                                                     FallbackValue=Collapsed}"/>
                                    </StackPanel>

                                    <!-- Column 2 — busy spinner while launching. -->
                                    <ProgressBar Grid.Column="2" Width="80" Height="4"
                                                 IsIndeterminate="True"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 Background="#22000000" BorderThickness="0"
                                                 Margin="0,0,12,0"
                                                 VerticalAlignment="Center"
                                                 Visibility="{Binding IsLaunching,
                                                   Converter={StaticResource BoolToVis}}"/>

                                    <!-- Single gear icon, where the "Idle" text used to
                                         be. Clicking opens the profile editor. -->
                                    <Button Grid.Column="3"
                                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                            Content="" FontSize="14"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource TextSecondary}"
                                            Padding="6,4" Cursor="Hand"
                                            ToolTip="Edit profile"
                                            Command="{Binding EditCommand}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasRows,
                              Converter={StaticResource InverseBoolToVis}}">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               Text="" FontSize="36"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock Text="No profiles yet" FontSize="14"
                               Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="Click + to create one"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bottom toolbar: + / − on the left, Launch on the right.
             Mirrors macOS ProfilePickerView's "+ −" + "Open Session". -->
        <Border Grid.Row="2" Margin="20,4,20,16" Padding="6,4"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            Content="" FontSize="11"
                            Background="Transparent" BorderThickness="0"
                            Padding="8,4" Cursor="Hand"
                            ToolTip="New profile"
                            Command="{Binding NewProfileCommand}"/>
                    <Button FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            Content="" FontSize="11"
                            Background="Transparent" BorderThickness="0"
                            Padding="8,4" Cursor="Hand"
                            ToolTip="Delete selected profile"
                            IsEnabled="{Binding HasSelection}"
                            Command="{Binding DeleteSelectedCommand}"/>
                </StackPanel>
                <Button Grid.Column="2" Padding="16,6" Margin="0,0,4,0"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White" BorderThickness="0"
                        FontWeight="SemiBold" Cursor="Hand"
                        IsEnabled="{Binding HasSelection}"
                        Command="{Binding LaunchSelectedCommand}"
                        Visibility="{Binding Selected.IsRunning,
                          Converter={StaticResource InverseBoolToVis},
                          FallbackValue=Visible}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Text="" FontSize="11"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Launch" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Padding="16,6"
                        Background="{StaticResource DangerBrush}"
                        Foreground="White" BorderThickness="0"
                        FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding StopSelectedCommand}"
                        Visibility="{Binding Selected.IsRunning,
                          Converter={StaticResource BoolToVis},
                          FallbackValue=Collapsed}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Text="" FontSize="11"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Stop" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>

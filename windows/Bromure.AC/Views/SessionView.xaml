<UserControl x:Class="Bromure.AC.Views.SessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ChromeBackground}"
             Foreground="{StaticResource TextPrimary}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar — analogous to the macOS unified titlebar -->
        <Border Grid.Row="0" Background="{StaticResource PanelBackground}"
                BorderBrush="#22FFFFFF" BorderThickness="0,0,0,1">
            <Grid Margin="16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="10" Height="10" CornerRadius="5"
                            Background="{Binding StatusBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding ProfileName}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding VmStatus, StringFormat=' · {0}'}"
                               Foreground="{StaticResource TextSecondary}" Margin="6,0,0,0"/>
                </StackPanel>

                <!-- Tab strip — one pill per kitty tab. Active tab gets a
                     darker pill; clicking activates; "x" closes; "+" adds a
                     fresh distro. Mirrors the macOS port's per-kitty tabs. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ItemsControl ItemsSource="{Binding Tabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2" Padding="10,4" CornerRadius="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#22FFFFFF"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="#55FFFFFF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{Binding Label}" FontSize="11"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{StaticResource TextPrimary}"
                                                Cursor="Hand" Padding="0"
                                                Command="{Binding DataContext.ActivateTabCommand,
                                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="×" FontSize="12"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{StaticResource TextSecondary}"
                                                Margin="6,0,0,0" Padding="0" Cursor="Hand"
                                                ToolTip="Close tab"
                                                Command="{Binding DataContext.CloseTabCommand,
                                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="+" Margin="6,0,0,0" Padding="8,4"
                            Background="#33FFFFFF" Foreground="{StaticResource TextPrimary}"
                            BorderThickness="0" Cursor="Hand"
                            FontSize="13" FontWeight="Bold"
                            ToolTip="New tab"
                            Command="{Binding NewTabCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding IpAddress, StringFormat='IP {0}'}"
                               Foreground="{StaticResource TextSecondary}"
                               FontFamily="Consolas" Margin="0,0,12,0"/>
                    <Button Content="Boot session" Padding="14,4"
                            Background="{StaticResource AccentBrush}"
                            Foreground="{StaticResource TextPrimary}"
                            BorderThickness="0" Cursor="Hand"
                            Margin="0,0,8,0"
                            Command="{Binding StartCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVis}}"/>
                    <Button Content="Shut down" Padding="10,4"
                            Command="{Binding ShutdownCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Display area. Two modes overlaid:
             1. Embedded WSLg-rendered kitty window via the active tab's
                ActiveDisplaySurface (a WslWindowHost).
             2. Idle status pane (pre-boot). -->
        <Grid Grid.Row="1" Background="#000000">
            <ContentControl Content="{Binding ActiveDisplaySurface}"
                            Visibility="{Binding HasDisplay, Converter={StaticResource BoolToVis}}"/>

            <!-- Idle pane (pre-boot). The QEMU port had a serial console
                 fallback here; WSL2 has no equivalent and doesn't need one. -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding VmStatus}" FontSize="14"
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding VmStatusDetail}" FontSize="11"
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"
                           TextAlignment="Center" MaxWidth="520" TextWrapping="Wrap"/>
                <ProgressBar Margin="0,16,0,0" Width="240" Height="4"
                             IsIndeterminate="True"
                             Foreground="{StaticResource AccentBrush}"
                             Background="#22FFFFFF" BorderThickness="0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <!-- Compromise overlay placeholder removed — ShowCompromiseOverlay
                 binding wasn't in the WSL2 SessionViewModel. Will return when
                 the leak-detection plumbing is ported. -->

            <!-- Failure panel: surfaces the actual QEMU stderr when boot
                 fails so "could not connect to QMP" becomes a specific
                 error the user can hand off. -->
            <Border Visibility="{Binding HasFailure, Converter={StaticResource BoolToVis}}"
                    Background="#000000" Opacity="0.94">
                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="QEMU couldn't start"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource DangerBrush}"/>
                    <TextBlock Grid.Row="1" Margin="0,8,0,0"
                               Text="{Binding VmStatusDetail}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11" TextWrapping="Wrap"/>
                    <Border Grid.Row="2" Background="#16161B" CornerRadius="6"
                            Padding="12" Margin="0,16,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding FailureDetail}"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="#FF8E96"
                                       TextWrapping="NoWrap"/>
                        </ScrollViewer>
                    </Border>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0"
                                HorizontalAlignment="Right">
                        <TextBlock Text="{Binding StderrLogPath, StringFormat='log: {0}'}"
                                   FontFamily="Consolas" FontSize="10"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="0,0,16,0"
                                   TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                        <Button Content="Open log" Padding="10,6" Margin="0,0,8,0"
                                Command="{Binding OpenLogCommand}"/>
                        <Button Content="Copy" Padding="10,6" Margin="0,0,8,0"
                                Command="{Binding CopyLogCommand}"/>
                        <Button Content="Dismiss" Padding="10,6"
                                Command="{Binding DismissFailureCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer status bar -->
        <Border Grid.Row="2" Background="{StaticResource PanelBackground}"
                BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0">
            <Grid Margin="16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding LastEvent}"
                           Foreground="{StaticResource TextSecondary}"
                           FontFamily="Consolas" FontSize="11"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Text="{Binding TraceCount, StringFormat='{}{0} traces'}"
                           Foreground="{StaticResource TextSecondary}" FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

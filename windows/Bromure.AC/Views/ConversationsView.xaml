<UserControl x:Class="Bromure.AC.Views.ConversationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ChromeBackground}"
             Foreground="{StaticResource TextPrimary}">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Conversations"
                   FontSize="22" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="0" Margin="0,30,0,0"
                   Foreground="{StaticResource TextSecondary}" FontSize="11">
            Chat-style view of every LLM exchange the proxy captured.
            Bodies decrypt on demand through the engine's secrets vault.
        </TextBlock>

        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Padding="8,6" Margin="0,0,8,0"
                     Background="{StaticResource PanelBackground}"
                     Foreground="{StaticResource TextPrimary}"
                     BorderThickness="1" BorderBrush="#33FFFFFF"
                     Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Filter by host or path"/>
            <Button Grid.Column="1" Content="Refresh" Padding="14,6"
                    Background="{StaticResource AccentBrush}"
                    Foreground="{StaticResource TextPrimary}"
                    BorderThickness="0" Cursor="Hand"
                    Command="{Binding RefreshCommand}"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Conversation list (left) -->
            <ListBox Grid.Column="0" ItemsSource="{Binding Rows}"
                     SelectedItem="{Binding Selected}"
                     Background="{StaticResource PanelBackground}"
                     Foreground="{StaticResource TextPrimary}"
                     BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,4">
                            <TextBlock Text="{Binding TimestampLocal}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock Text="{Binding Subtitle}"
                                       FontFamily="Consolas" FontSize="11"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Selected conversation (right) -->
            <Grid Grid.Column="1" Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            Margin="0,0,0,8">
                    <TextBlock Text="{Binding SelectedProviderLabel}"
                               FontWeight="SemiBold"
                               Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding SelectedModel}"
                               Foreground="{StaticResource TextSecondary}"
                               FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource PanelBackground}">
                    <ItemsControl ItemsSource="{Binding Messages}" Margin="12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="10"
                                        Margin="0,4"
                                        Background="{Binding Background}"
                                        HorizontalAlignment="{Binding HorizontalAlignment}"
                                        MaxWidth="640">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Role}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="#CCFFFFFF"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Text}"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

<Window x:Class="Bromure.AC.Views.ConsentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Consent — Bromure AC"
        Width="500" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource ChromeBackground}"
        Foreground="{StaticResource TextPrimary}"
        ShowInTaskbar="False"
        Topmost="True">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Border Width="36" Height="36" CornerRadius="8"
                    Background="{StaticResource AccentBrush}" Margin="0,0,12,0">
                <TextBlock Text="!" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimary}"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding HeaderText}" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding ScopeHint}" FontSize="11"
                           Foreground="{StaticResource TextSecondary}"
                           TextWrapping="Wrap" MaxWidth="380"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource PanelBackground}"
                CornerRadius="6" Padding="14,10" Margin="0,18,0,0">
            <StackPanel>
                <TextBlock Text="{Binding CredentialDisplayName}" FontWeight="SemiBold"
                           FontFamily="Consolas"/>
                <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                           Margin="0,4,0,0" TextWrapping="Wrap">
                    Bromure intercepts this credential on the wire. Allow
                    grants survive only as long as you choose; choosing
                    "Don't allow" silences the same prompt for 5 minutes.
                </TextBlock>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" VerticalAlignment="Bottom" Margin="0,18,0,0">
            <Button Content="Allow for 1 hour" Padding="12,10" Margin="0,0,0,8"
                    Background="{StaticResource AccentBrush}"
                    Foreground="{StaticResource TextPrimary}"
                    BorderThickness="0" Cursor="Hand"
                    Click="OnAllow1Hr"/>
            <Button Content="Allow for 5 minutes" Padding="12,10" Margin="0,0,0,8"
                    Click="OnAllow5Min"/>
            <Button Content="Allow for the rest of the session" Padding="12,10" Margin="0,0,0,8"
                    Click="OnAllowSession"/>
            <Button Content="Don't allow" Padding="12,10"
                    Foreground="{StaticResource DangerBrush}"
                    Click="OnDeny"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Foreground="{StaticResource TextSecondary}" FontSize="10"
                   Margin="0,10,0,0" TextWrapping="Wrap">
            Closing the dialog without choosing counts as "Don't allow".
        </TextBlock>
    </Grid>
</Window>

<Window x:Class="Bromure.AC.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Bromure.AC.ViewModels"
        xmlns:views="clr-namespace:Bromure.AC.Views"
        xmlns:loc="clr-namespace:Bromure.AC.Localization"
        Title="{Binding WindowTitle, FallbackValue='Bromure Agentic Coding'}"
        Height="780" Width="1180"
        Icon="/BromureAC.ico"
        Background="{StaticResource ChromeBackground}"
        Foreground="{StaticResource TextPrimary}"
        WindowStartupLocation="CenterScreen">
    <Window.InputBindings>
        <!-- Keyboard shortcuts (macOS parity, Cmd→Ctrl). UX #6: the
             sidebar is gone; secondary panes are reached via the View
             menu or the shortcuts here. Ctrl+1 = Sessions (the
             default), Ctrl+2 = Profiles (manage list), then everything
             else lives behind a single chord since the user shouldn't
             need to think about Approvals/Trace daily. -->
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewSessionCommand}"/>
        <KeyBinding Key="W" Modifiers="Control" Command="{x:Static SystemCommands.CloseWindowCommand}"/>
        <KeyBinding Key="D1" Modifiers="Control"
                    Command="{Binding GoToNavigationCommand}" CommandParameter="Sessions"/>
        <KeyBinding Key="D2" Modifiers="Control"
                    Command="{Binding GoToNavigationCommand}" CommandParameter="Profiles"/>
        <KeyBinding Key="OemComma" Modifiers="Control"
                    Command="{Binding GoToNavigationCommand}" CommandParameter="Settings"/>
        <KeyBinding Key="I" Modifiers="Control+Shift"
                    Command="{Binding GoToNavigationCommand}" CommandParameter="TraceInspector"/>
        <KeyBinding Key="F1" Command="{Binding OpenDocumentationCommand}"/>
        <!-- Audit 08 — Ctrl+M minimizes (matches the new Window menu
             accelerator). Routes through MinimizeWindowCommand so any
             attached behavior fires uniformly. -->
        <KeyBinding Key="M" Modifiers="Control"
                    Command="{x:Static SystemCommands.MinimizeWindowCommand}"/>
    </Window.InputBindings>
    <!--
        Two layers of overlay-by-Visibility (no ContentTemplateSelector).
        WPF's selector is only re-evaluated when Content itself changes,
        so a property change on the bound object (Phase, SelectedNavigation)
        wouldn't refresh the pane. Visibility binds re-evaluate on every
        property change. Cheap: views past the active one are
        Collapsed → not realised, no draw cost.
    -->
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="{StaticResource PanelBackground}"
              Foreground="{StaticResource TextPrimary}">
            <MenuItem Header="{x:Static loc:Strings.MenuFile}">
                <MenuItem Header="{x:Static loc:Strings.MenuFileNewSession}" InputGestureText="Ctrl+N"
                          Command="{Binding NewSessionCommand}"/>
                <Separator/>
                <!-- Audit 10 §0.5: explicit Rebuild Base Image entry
                     point. Navigates to Settings where the build/
                     rebuild button lives. -->
                <MenuItem Header="{x:Static loc:Strings.MenuFileRebuildBase}"
                          Command="{Binding GoToNavigationCommand}" CommandParameter="Settings"/>
                <Separator/>
                <MenuItem Header="{x:Static loc:Strings.MenuFileCloseWindow}" InputGestureText="Ctrl+W"
                          Command="{x:Static SystemCommands.CloseWindowCommand}"/>
                <MenuItem Header="{x:Static loc:Strings.MenuFileExit}"
                          Command="{x:Static SystemCommands.CloseWindowCommand}"/>
            </MenuItem>
            <!-- Edit menu — standard routed commands. Each MenuItem
                 picks up enabled-state from the focused input control
                 (TextBox / PasswordBox / DataGrid…). Users don't strictly
                 need this for muscle-memory Ctrl+C/V/X/A to work, but
                 having the menu makes the affordance discoverable and
                 matches every other Windows app. Audit §8 follow-up. -->
            <MenuItem Header="{x:Static loc:Strings.MenuEdit}">
                <MenuItem Header="{x:Static loc:Strings.MenuEditCut}" InputGestureText="Ctrl+X"
                          Command="ApplicationCommands.Cut"/>
                <MenuItem Header="{x:Static loc:Strings.MenuEditCopy}" InputGestureText="Ctrl+C"
                          Command="ApplicationCommands.Copy"/>
                <MenuItem Header="{x:Static loc:Strings.MenuEditPaste}" InputGestureText="Ctrl+V"
                          Command="ApplicationCommands.Paste"/>
                <Separator/>
                <MenuItem Header="{x:Static loc:Strings.MenuEditSelectAll}" InputGestureText="Ctrl+A"
                          Command="ApplicationCommands.SelectAll"/>
            </MenuItem>
            <MenuItem Header="{x:Static loc:Strings.MenuView}">
                <MenuItem Header="{x:Static loc:Strings.MenuViewSessions}" InputGestureText="Ctrl+1"
                          Command="{Binding GoToNavigationCommand}" CommandParameter="Sessions"/>
                <MenuItem Header="{x:Static loc:Strings.MenuViewProfiles}" InputGestureText="Ctrl+2"
                          Command="{Binding GoToNavigationCommand}" CommandParameter="Profiles"/>
                <Separator/>
                <MenuItem Header="{x:Static loc:Strings.MenuViewTrace}" InputGestureText="Ctrl+Shift+I"
                          Command="{Binding GoToNavigationCommand}" CommandParameter="TraceInspector"/>
                <MenuItem Header="{x:Static loc:Strings.MenuViewApprovals}"
                          Command="{Binding GoToNavigationCommand}" CommandParameter="Approvals"/>
                <Separator/>
                <MenuItem Header="{x:Static loc:Strings.MenuViewPreferences}" InputGestureText="Ctrl+,"
                          Command="{Binding GoToNavigationCommand}" CommandParameter="Settings"/>
            </MenuItem>
            <!-- Audit 08 — Window menu. Lists running sessions so a
                 hidden / minimized SessionWindow can be raised from
                 the picker. Items rebuilt on submenu open so the
                 list stays current without observable plumbing. -->
            <MenuItem Header="_Window" SubmenuOpened="OnWindowMenuOpened">
                <MenuItem Header="_Minimize" InputGestureText="Ctrl+M"
                          Click="OnMinimizeMainWindow"/>
                <MenuItem Header="_Bring Picker to Front"
                          Click="OnBringMainToFront"/>
                <Separator x:Name="WindowMenuSeparator"/>
                <!-- Per-session items appended in OnWindowMenuOpened.
                     A placeholder communicates the "no sessions" state. -->
                <MenuItem x:Name="WindowMenuEmpty" Header="(no running sessions)"
                          IsEnabled="False"/>
            </MenuItem>
            <MenuItem Header="{x:Static loc:Strings.MenuHelp}">
                <MenuItem Header="{x:Static loc:Strings.MenuHelpDocs}" InputGestureText="F1"
                          Command="{Binding OpenDocumentationCommand}"/>
                <!-- Audit 08 — Check for Updates. Interactive
                     check via HttpAppUpdater; shows a MessageBox
                     whether or not an update is available. -->
                <MenuItem Header="{x:Static loc:Strings.MenuHelpUpdates}"
                          Click="OnCheckForUpdatesClick"/>
                <Separator/>
                <MenuItem Header="{x:Static loc:Strings.MenuHelpAbout}"
                          Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>
        <!-- UX #6: sidebar removed. Main content fills the window;
             secondary panes (Profiles, Trace, Approvals, Settings)
             live under the View menu so the daily UX is "just
             sessions", macOS-style. ImageInfoLine moved to a status
             strip at the bottom. -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource PanelBackground}"
                BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0"
                Padding="14,4">
            <TextBlock Text="{Binding ImageInfoLine}" FontSize="11"
                       Foreground="{StaticResource TextSecondary}"
                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
        </Border>

        <Grid>
            <!-- Sessions pane = profile picker + (when image not built) a
                 setup overlay. Mirrors macOS ProfilePickerView /
                 SetupView split. -->
            <Grid Visibility="{Binding SelectedNavigation.Kind,
                              Converter={StaticResource EnumToVis},
                              ConverterParameter=Sessions}">
                <views:WelcomeView
                    Visibility="{Binding Phase,
                                Converter={StaticResource EnumToVis},
                                ConverterParameter=Welcome}"/>
                <views:InitializingView DataContext="{Binding Progress}"
                    Visibility="{Binding DataContext.Phase,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={StaticResource EnumToVis},
                                ConverterParameter=Initializing}"/>
                <views:SessionsView DataContext="{Binding SessionsPane}"
                    Visibility="{Binding DataContext.Phase,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={StaticResource EnumToVis},
                                ConverterParameter=Session}"/>
            </Grid>

            <views:ProfilesView DataContext="{Binding ProfilesPane}"
                Visibility="{Binding DataContext.SelectedNavigation.Kind,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource EnumToVis},
                            ConverterParameter=Profiles}"/>

            <!-- UX #6: ConversationsView removed. Its content (per-session
                 LLM conversation rendering) is now reachable from the
                 Trace Inspector — every llm.request body is already
                 captured by the trace store; the inspector groups by
                 conversation when expanded. -->

            <views:TraceInspectorView DataContext="{Binding TraceInspectorPane}"
                Visibility="{Binding DataContext.SelectedNavigation.Kind,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource EnumToVis},
                            ConverterParameter=TraceInspector}"/>

            <views:ApprovalsView DataContext="{Binding ApprovalsPane}"
                Visibility="{Binding DataContext.SelectedNavigation.Kind,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource EnumToVis},
                            ConverterParameter=Approvals}"/>

            <views:SettingsView DataContext="{Binding SettingsPane}"
                Visibility="{Binding DataContext.SelectedNavigation.Kind,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource EnumToVis},
                            ConverterParameter=Settings}"/>

            <!-- Ubuntu base-image bake overlay. Sits as the last child
                 inside the main Grid so it overlays every content
                 pane; bound to BakeOverlay.IsVisible. -->
            <views:BakeOverlay DataContext="{Binding BakeOverlay}"
                              Visibility="{Binding IsVisible, FallbackValue=Collapsed,
                                           Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </DockPanel>
</Window>


<Window x:Class="Bromure.AC.Views.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Bromure.AC.Views"
        Title="Edit profile"
        Width="700" Height="640"
        Background="{StaticResource ChromeBackground}"
        Foreground="{StaticResource TextPrimary}"
        WindowStartupLocation="CenterOwner">
    <!-- Wraps the existing ProfilesView (the full editor). Mirrors the
         macOS port's separate editorWindow opened from
         ProfilePickerView's onEdit callback. -->
    <views:ProfilesView/>
</Window>

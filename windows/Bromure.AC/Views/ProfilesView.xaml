<UserControl x:Class="Bromure.AC.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cmn="clr-namespace:Bromure.AC.Common"
             Background="{StaticResource ChromeBackground}"
             Foreground="{StaticResource TextPrimary}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" x:Name="PickerColumn"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: profile list. Hidden by ProfilesView code-behind
             when EditorOnly is set on the bound view-model — that
             flag is true for the ProfileEditorWindow popup so the
             user only sees the one profile they clicked Edit on. -->
        <Border Grid.Column="0" Background="{StaticResource PanelBackground}"
                BorderBrush="#22000000" BorderThickness="0,0,1,0"
                Visibility="{Binding EditorOnly, Converter={StaticResource InverseBoolToVis}}">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="14,18,14,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Profiles" FontSize="16" FontWeight="SemiBold"/>
                    <Button Grid.Column="1" Content="+" Width="28" Height="28"
                            FontSize="16" FontWeight="Bold"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding AddProfileCommand}"
                            ToolTip="Add a profile"/>
                </Grid>

                <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding Selected}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Audit 09 §A1: the dot reflects the profile's
                                     chosen color, matching the editor swatch +
                                     SessionsView pill. Previously always blue. -->
                                <Border Grid.Column="0" Width="10" Height="10"
                                        CornerRadius="5"
                                        Background="{Binding Color, Converter={StaticResource ProfileColorToBrush}}"
                                        Margin="0,2,8,0" VerticalAlignment="Top"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Tool}" FontSize="11"
                                               Foreground="{StaticResource TextSecondary}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- RIGHT: editor -->
        <Grid Grid.Column="1" Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header strip -->
            <Border Grid.Row="0" Background="{StaticResource PanelBackground}"
                    BorderBrush="#22000000" BorderThickness="0,0,0,1"
                    Padding="32,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Selected.Name, FallbackValue='—'}"
                                   FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11">
                            <Run Text="{Binding Selected.Tool, Mode=OneWay}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding Selected.AuthMode, Mode=OneWay}"/>
                            <Run Text=" · trace "/>
                            <Run Text="{Binding Selected.TraceLevel, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Cancel reverts in-memory edits to the
                             on-disk state. Save persists. The Delete
                             affordance moved to the per-row context
                             menu in the picker (audit 08 §2.4) — it
                             was confusing as a primary header button. -->
                        <Button Content="Cancel" Margin="0,0,8,0"
                                Command="{Binding CancelCommand}"/>
                        <Button Content="Save" Style="{StaticResource AccentButton}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Editor — macOS-style category sidebar on the left,
                 content pane on the right. Same shape as Windows
                 Settings + macOS System Settings, so a user
                 switching platforms doesn't have to hunt for things.
                 Implemented as a TabControl with TabStripPlacement=Left
                 + a custom TabItem template (icon + label, with a
                 selected indicator) — keeps the existing per-tab
                 content unchanged so this is a pure visual refactor. -->
            <TabControl Grid.Row="1" DataContext="{Binding Selected}"
                        Background="Transparent" BorderThickness="0"
                        Padding="0" TabStripPlacement="Left">
                <TabControl.Resources>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
                    </Style>
                    <!-- Category-list tab item. Tag carries the Segoe
                         Fluent Icons glyph (rendered with the same
                         font the sessions sidebar uses). Selected
                         state paints an accent background + accent
                         text, matching Windows Settings. -->
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        <Setter Property="Padding" Value="14,10"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Margin" Value="6,2"/>
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="row"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{TemplateBinding Tag}"
                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="16"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       Width="24"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <ContentPresenter ContentSource="Header"
                                                              VerticalAlignment="Center"
                                                              Margin="10,0,0,0"
                                                              RecognizesAccessKey="True"
                                                              TextElement.FontSize="{DynamicResource FontSizeBody}"
                                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="row" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="row" Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Background="{DynamicResource PanelElevated}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,1,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="0,16">
                                    <TabPanel IsItemsHost="True" Background="Transparent"/>
                                </ScrollViewer>
                            </Border>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource PanelBackground}"
                                    Padding="32,20">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>

                <!-- ================================================
                     GENERAL TAB
                     ================================================ -->
                <TabItem Header="General" Tag="">
                    <ScrollViewer>
                        <StackPanel MaxWidth="640">
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Display name"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                                <TextBox  Grid.Row="0" Grid.Column="1"
                                          Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,4"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Accent colour"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                                <!-- Audit 09 §A1: macOS shows a filled gradient
                                     circle next to each color name. WPF needs a
                                     DataTemplate to render the swatch alongside
                                     the label. -->
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          ItemsSource="{Binding DataContext.ColorOptions,
                                                       RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding Color}"
                                          Margin="0,4">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="12" Height="12"
                                                         Fill="{Binding Converter={StaticResource ProfileColorToBrush}}"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Primary tool"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                                <ComboBox Grid.Row="2" Grid.Column="1"
                                          ItemsSource="{Binding DataContext.ToolOptions,
                                                       RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding Tool}"
                                          Margin="0,4"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Auth mode"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                                <ComboBox Grid.Row="3" Grid.Column="1"
                                          ItemsSource="{Binding DataContext.AuthModeOptions,
                                                       RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding AuthMode}"
                                          Margin="0,4"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="API key"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                                <PasswordBox Grid.Row="4" Grid.Column="1" Margin="0,4"
                                             cmn:PasswordBoxBinding.Password="{Binding ApiKey, Mode=TwoWay}"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="API key requires approval"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                                <CheckBox Grid.Row="5" Grid.Column="1"
                                          Content="Prompt before each use"
                                          IsChecked="{Binding ApiKeyRequiresApproval}"
                                          Margin="0,8"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Trace level"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                                <ComboBox Grid.Row="6" Grid.Column="1"
                                          ItemsSource="{Binding DataContext.TraceLevelOptions,
                                                       RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding TraceLevel}"
                                          Margin="0,4"/>
                            </Grid>

                            <!-- Audit 09 §A2 — additional tools. macOS lets the
                                 user enable Claude AND Codex (and any future
                                 tool) on the same profile with independent
                                 auth modes. Each ToolSpec rows binds straight
                                 against an entry in AdditionalTools. -->
                            <Border Background="{StaticResource PanelBackground}" CornerRadius="6"
                                    Padding="20" Margin="0,12,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Additional tools" FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Button Content="+ Add"
                                                Margin="12,0,0,0" Padding="10,2"
                                                Command="{Binding DataContext.AddAdditionalToolCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </StackPanel>
                                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,8,0,0">
                                        Enables a second (or third) agent CLI alongside the primary tool.
                                        Each tool has its own auth mode + key.
                                    </TextBlock>
                                    <ItemsControl ItemsSource="{Binding AdditionalTools}" Margin="0,12,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource PanelElevated}"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="140"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tool"
                                                                   Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                        <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,2"
                                                                  ItemsSource="{Binding DataContext.ToolOptions,
                                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedItem="{Binding Tool}"/>
                                                        <Button Grid.Row="0" Grid.Column="2"
                                                                Content="Remove"
                                                                Style="{StaticResource DangerButton}"
                                                                Margin="8,0,0,0" Padding="10,2"
                                                                Command="{Binding DataContext.RemoveAdditionalToolCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Auth mode"
                                                                   Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                        <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,2"
                                                                  ItemsSource="{Binding DataContext.AuthModeOptions,
                                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedItem="{Binding AuthMode}"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="API key"
                                                                   Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                        <PasswordBox Grid.Row="2" Grid.Column="1" Margin="0,2"
                                                                     cmn:PasswordBoxBinding.Password="{Binding ApiKey, Mode=TwoWay}"/>
                                                        <CheckBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,0"
                                                                  Content="Prompt before each use"
                                                                  IsChecked="{Binding RequireApproval}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource PanelBackground}" CornerRadius="6"
                                    Padding="20" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Privacy" FontSize="14" FontWeight="SemiBold"/>
                                    <CheckBox Margin="0,12,0,0"
                                              Content="Private mode — exclude this profile's traffic from cloud telemetry"
                                              IsChecked="{Binding PrivateMode}"/>
                                </StackPanel>
                            </Border>

                            <!-- Audit 09 §A7: subscription token swap state row.
                                 Shows whether the user has accepted/declined the
                                 swap prompt for Claude / Codex on this profile,
                                 with a button to reset the decision so the
                                 prompt fires again on next swap detection. -->
                            <Border Background="{StaticResource PanelBackground}" CornerRadius="6"
                                    Padding="20" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Subscription token swap" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,4,0,8">
                                        Whether the proxy swaps real Anthropic / OpenAI OAuth tokens with fakes
                                        before they reach the VM. Reset to clear the decision and re-prompt
                                        next time a fresh token is observed.
                                    </TextBlock>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Claude (Anthropic)" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Margin="12,0,0,0"
                                                   Text="{Binding SubscriptionTokenSwap, Mode=OneWay}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Content="Reset"
                                                Padding="12,4"
                                                Command="{Binding DataContext.ResetSubscriptionSwapCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Codex (ChatGPT)" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Margin="12,0,0,0"
                                                   Text="{Binding CodexTokenSwap, Mode=OneWay}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Content="Reset"
                                                Padding="12,4"
                                                Command="{Binding DataContext.ResetCodexSwapCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ================================================
                     FOLDERS TAB
                     ================================================ -->
                <TabItem Header="Folders" Tag="">
                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,0,0,12">
                                Each folder mounts at /home/ubuntu/&lt;basename&gt; in the guest.
                                Capped at 8 (the base image's fstab pre-allocation).
                            </TextBlock>

                            <ItemsControl ItemsSource="{Binding FolderPaths}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{StaticResource PanelBackground}"
                                                    Padding="12,8" CornerRadius="3">
                                                <TextBlock Text="{Binding}" FontFamily="Consolas"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <Button Grid.Column="1" Content="Remove" Margin="8,0,0,0"
                                                    Style="{StaticResource DangerButton}"
                                                    Command="{Binding DataContext.RemoveFolderCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Content="Add folder…" Margin="0,12,0,0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource AccentButton}"
                                    Command="{Binding DataContext.AddFolderCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ================================================
                     CREDENTIALS TAB — accordion of credential types
                     ================================================ -->
                <TabItem Header="Credentials" Tag="">
                    <ScrollViewer>
                        <StackPanel>
                            <!-- AWS ............................................. -->
                            <Expander Header="AWS" IsExpanded="True" Margin="0,0,0,8">
                                <Border Background="{StaticResource PanelBackground}" CornerRadius="6" Padding="16">
                                    <StackPanel DataContext="{Binding Aws}">
                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                                   Margin="0,0,0,12" TextWrapping="Wrap">
                                            Real AWS credentials live on the host. The proxy strips the
                                            guest's signature and re-signs with these before the
                                            request leaves the machine. Configure once; use anywhere.
                                        </TextBlock>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Auth mode"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                                            <ComboBox Grid.Row="0" Grid.Column="1"
                                                      ItemsSource="{Binding DataContext.AwsAuthModes,
                                                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedItem="{Binding AuthMode}"
                                                      Margin="0,4"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="SSO profile"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                                            <TextBox Grid.Row="1" Grid.Column="1"
                                                     Text="{Binding SsoProfile, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,4"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Access key ID"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                                            <TextBox Grid.Row="2" Grid.Column="1" FontFamily="Consolas"
                                                     Text="{Binding AccessKeyId, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,4"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Secret access key"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                                            <PasswordBox Grid.Row="3" Grid.Column="1" Margin="0,4"
                                                         cmn:PasswordBoxBinding.Password="{Binding SecretAccessKey, Mode=TwoWay}"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Session token"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                                            <PasswordBox Grid.Row="4" Grid.Column="1" Margin="0,4"
                                                         cmn:PasswordBoxBinding.Password="{Binding SessionToken, Mode=TwoWay}"/>

                                            <CheckBox Grid.Row="5" Grid.Column="1" Margin="0,8,0,0"
                                                      Content="Prompt before each AWS call"
                                                      IsChecked="{Binding RequireApproval}"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <Button Content="Discover from ~/.aws/config" Margin="0,0,8,0"
                                                    Command="{Binding DataContext.DiscoverAwsSsoCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            <!-- Audit 09 §A4: "Open IAM credentials page" launcher.
                                                 Drops the user in the AWS console's security-credentials
                                                 view so they can create / rotate access keys. -->
                                            <Button Content="Open IAM credentials page"
                                                    Command="{Binding DataContext.OpenAwsIamCredentialsPageCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <!-- AWS Bedrock (audit 09 §A2) ....................... -->
                            <Expander Header="AWS Bedrock" Margin="0,8,0,8">
                                <Border Background="{StaticResource PanelBackground}" CornerRadius="6" Padding="16">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                                   Margin="0,0,0,12" TextWrapping="Wrap">
                                            Route Claude calls through Bedrock instead of api.anthropic.com.
                                            Uses the AWS credentials configured above for SigV4 signing.
                                        </TextBlock>
                                        <CheckBox Content="Enable Bedrock for this profile"
                                                  IsChecked="{Binding BedrockEnabled}"
                                                  Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Model ID"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,8"
                                                       VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Margin="0,4" FontFamily="Consolas"
                                                     IsEnabled="{Binding BedrockEnabled}"
                                                     Text="{Binding BedrockModelID, UpdateSourceTrigger=LostFocus}"/>
                                        </Grid>
                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="10"
                                                   Margin="0,4,0,0" TextWrapping="Wrap">
                                            Example: anthropic.claude-3-5-sonnet-20241022-v2:0
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <!-- DigitalOcean access token (audit 09 §A4) ........ -->
                            <Expander Header="DigitalOcean" Margin="0,8,0,8">
                                <Border Background="{StaticResource PanelBackground}" CornerRadius="6" Padding="16">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                                   Margin="0,0,0,12" TextWrapping="Wrap">
                                            Personal access token for the DigitalOcean API +
                                            <Hyperlink NavigateUri="https://cloud.digitalocean.com/account/api/tokens"
                                                       RequestNavigate="OnHyperlinkNavigate">
                                                doctl
                                            </Hyperlink>.
                                            The proxy swaps a fake into the guest's environment;
                                            the real value never leaves the host.
                                        </TextBlock>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Token"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,8"
                                                       VerticalAlignment="Center"/>
                                            <PasswordBox Grid.Column="1" Margin="0,4"
                                                         cmn:PasswordBoxBinding.Password="{Binding DigitalOceanToken, Mode=TwoWay}"/>
                                        </Grid>
                                        <CheckBox Margin="0,8,0,0"
                                                  Content="Prompt before each DigitalOcean call"
                                                  IsChecked="{Binding DigitalOceanRequiresApproval}"/>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <!-- Git identity (audit 09 §A4) ...................... -->
                            <Expander Header="Git identity" Margin="0,8,0,8" IsExpanded="True">
                                <Border Background="{StaticResource PanelBackground}" CornerRadius="6" Padding="16">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                                   Margin="0,0,0,12" TextWrapping="Wrap">
                                            Written to ~/.gitconfig in the guest as
                                            [user] name / email. Optional — leave blank to inherit
                                            the system default.
                                        </TextBlock>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="user.name"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4"
                                                     Text="{Binding GitUserName, UpdateSourceTrigger=LostFocus}"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="user.email"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4"
                                                     Text="{Binding GitUserEmail, UpdateSourceTrigger=LostFocus}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <!-- Git HTTPS ........................................ -->
                            <Expander Header="Git HTTPS credentials" Margin="0,8,0,8">
                                <Border Background="{StaticResource PanelBackground}" CornerRadius="6" Padding="16">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                                   Margin="0,0,0,12" TextWrapping="Wrap">
                                            Personal access tokens for forge hosts. Written to
                                            ~/.git-credentials in the guest; the proxy swaps the fake
                                            for the real value on the wire.
                                        </TextBlock>
                                        <ItemsControl ItemsSource="{Binding GitHttpsCredentials}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F2F2F4" CornerRadius="4"
                                                            Padding="12" Margin="0,4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Host"
                                                                       Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                            <TextBox Grid.Row="0" Grid.Column="1" FontFamily="Consolas"
                                                                     Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                                                                     Margin="0,2"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Username"
                                                                       Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                            <TextBox Grid.Row="1" Grid.Column="1"
                                                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                                                     Margin="0,2"/>
                                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Token"
                                                                       Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                            <PasswordBox Grid.Row="2" Grid.Column="1" Margin="0,2"
                                                                         cmn:PasswordBoxBinding.Password="{Binding Token, Mode=TwoWay}"/>
                                                            <CheckBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,0"
                                                                      Content="Require approval"
                                                                      IsChecked="{Binding RequireApproval}"/>
                                                            <Button Grid.Row="4" Grid.Column="1" Content="Remove" Margin="0,8,0,0"
                                                                    HorizontalAlignment="Left"
                                                                    Style="{StaticResource DangerButton}"
                                                                    Command="{Binding DataContext.RemoveGitCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <Button Content="Add Git credential"
                                                    Style="{StaticResource AccentButton}"
                                                    Margin="0,0,8,0"
                                                    Command="{Binding DataContext.AddGitCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            <!-- Audit 09 §A4: per-forge "open token page" launchers
                                                 matching the macOS GitHttpsRow.openTokenPage shortcuts. -->
                                            <Button Content="Open GitHub tokens"
                                                    Margin="0,0,8,0"
                                                    Command="{Binding DataContext.OpenGitHubTokensPageCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            <Button Content="Open GitLab tokens"
                                                    Margin="0,0,8,0"
                                                    Command="{Binding DataContext.OpenGitLabTokensPageCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            <Button Content="Open Bitbucket tokens"
                                                    Command="{Binding DataContext.OpenBitbucketTokensPageCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <!-- Manual tokens .................................... -->
                            <Expander Header="Manual tokens" Margin="0,8,0,8">
                                <Border Background="{StaticResource PanelBackground}" CornerRadius="6" Padding="16">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                                   Margin="0,0,0,12" TextWrapping="Wrap">
                                            User-defined fake↔real swaps. Each entry can pin to a host
                                            and optionally export the fake as a guest env var.
                                        </TextBlock>
                                        <ItemsControl ItemsSource="{Binding ManualTokens}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F2F2F4" CornerRadius="4"
                                                            Padding="12" Margin="0,4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="120"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"
                                                                       Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                            <TextBox Grid.Row="0" Grid.Column="1"
                                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                     Margin="0,2"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Value (real)"
                                                                       Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                            <!-- Audit 09 §A4: a small "eye" toggle lets the user
                                                                 verify what's in the field without copy-pasting.
                                                                 Per-row UI state via ElementName binding; not
                                                                 persisted to the model. -->
                                                            <Grid Grid.Row="1" Grid.Column="1" Margin="0,2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <PasswordBox Grid.Column="0"
                                                                             cmn:PasswordBoxBinding.Password="{Binding Value, Mode=TwoWay}"
                                                                             Visibility="{Binding IsChecked, ElementName=RevealValue,
                                                                                          Converter={StaticResource InverseBoolToVis}}"/>
                                                                <TextBox Grid.Column="0"
                                                                         Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         FontFamily="Consolas"
                                                                         Visibility="{Binding IsChecked, ElementName=RevealValue,
                                                                                      Converter={StaticResource BoolToVis}}"/>
                                                                <ToggleButton Grid.Column="1" x:Name="RevealValue"
                                                                              Content="👁"
                                                                              Margin="6,0,0,0" Padding="6,2"
                                                                              ToolTip="Reveal / hide value"
                                                                              Background="Transparent"
                                                                              BorderThickness="0"/>
                                                            </Grid>
                                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Env var"
                                                                       Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                            <TextBox Grid.Row="2" Grid.Column="1" FontFamily="Consolas"
                                                                     Text="{Binding EnvVarName, UpdateSourceTrigger=PropertyChanged}"
                                                                     Margin="0,2"/>
                                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Host filter"
                                                                       Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                            <TextBox Grid.Row="3" Grid.Column="1" FontFamily="Consolas"
                                                                     Text="{Binding HostFilter, UpdateSourceTrigger=PropertyChanged}"
                                                                     Margin="0,2"/>
                                                            <CheckBox Grid.Row="4" Grid.Column="1" Margin="0,8,0,0"
                                                                      Content="Require approval"
                                                                      IsChecked="{Binding RequireApproval}"/>
                                                            <Button Grid.Row="5" Grid.Column="1" Content="Remove" Margin="0,8,0,0"
                                                                    HorizontalAlignment="Left"
                                                                    Style="{StaticResource DangerButton}"
                                                                    Command="{Binding DataContext.RemoveManualCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Content="Add manual token" Margin="0,12,0,0"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource AccentButton}"
                                                Command="{Binding DataContext.AddManualCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <!-- Docker registries ................................ -->
                            <Expander Header="Docker registries" Margin="0,8,0,8">
                                <Border Background="{StaticResource PanelBackground}" CornerRadius="6" Padding="16">
                                    <StackPanel>
                                        <ItemsControl ItemsSource="{Binding DockerRegistries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F2F2F4" CornerRadius="4"
                                                            Padding="12" Margin="0,4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Host"
                                                                       Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                            <TextBox Grid.Row="0" Grid.Column="1" FontFamily="Consolas"
                                                                     Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                                                                     Margin="0,2"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Username"
                                                                       Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                            <TextBox Grid.Row="1" Grid.Column="1"
                                                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                                                     Margin="0,2"/>
                                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Password"
                                                                       Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                            <PasswordBox Grid.Row="2" Grid.Column="1" Margin="0,2"
                                                                         cmn:PasswordBoxBinding.Password="{Binding Password, Mode=TwoWay}"/>
                                                            <CheckBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,0"
                                                                      Content="Require approval"
                                                                      IsChecked="{Binding RequireApproval}"/>
                                                            <Button Grid.Row="4" Grid.Column="1" Content="Remove" Margin="0,8,0,0"
                                                                    HorizontalAlignment="Left"
                                                                    Style="{StaticResource DangerButton}"
                                                                    Command="{Binding DataContext.RemoveDockerCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Content="Add Docker registry" Margin="0,12,0,0"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource AccentButton}"
                                                Command="{Binding DataContext.AddDockerCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <!-- Kubeconfigs ...................................... -->
                            <Expander Header="Kubeconfigs" Margin="0,8,0,8">
                                <Border Background="{StaticResource PanelBackground}" CornerRadius="6" Padding="16">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                                   Margin="0,0,0,12" TextWrapping="Wrap">
                                            kubectl contexts. Currently supports bearer-token auth;
                                            client-cert + exec-plugin auth shapes ship in the underlying
                                            model but the editor for them is iterative.
                                        </TextBlock>
                                        <ItemsControl ItemsSource="{Binding Kubeconfigs}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F2F2F4" CornerRadius="4"
                                                            Padding="12" Margin="0,4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="120"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Context name"
                                                                       Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                            <TextBox Grid.Row="0" Grid.Column="1"
                                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                     Margin="0,2"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Server URL"
                                                                       Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                            <TextBox Grid.Row="1" Grid.Column="1" FontFamily="Consolas"
                                                                     Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}"
                                                                     Margin="0,2"/>
                                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Namespace"
                                                                       Foreground="{StaticResource TextSecondary}" Margin="0,4"/>
                                                            <TextBox Grid.Row="2" Grid.Column="1"
                                                                     Text="{Binding Namespace, UpdateSourceTrigger=PropertyChanged}"
                                                                     Margin="0,2"/>
                                                            <CheckBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,0"
                                                                      Content="Require approval"
                                                                      IsChecked="{Binding RequireApproval}"/>
                                                            <Button Grid.Row="4" Grid.Column="1" Content="Remove" Margin="0,8,0,0"
                                                                    HorizontalAlignment="Left"
                                                                    Style="{StaticResource DangerButton}"
                                                                    Command="{Binding DataContext.RemoveKubeCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <Button Content="Add kubeconfig"
                                                    Style="{StaticResource AccentButton}"
                                                    Command="{Binding DataContext.AddKubeCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            <!-- Audit 09 §A4: import every context from
                                                 a kubectl YAML in one shot. Mirrors macOS
                                                 profile editor's import flow. -->
                                            <Button Content="Import kubeconfig…" Margin="8,0,0,0"
                                                    Command="{Binding DataContext.ImportKubeconfigCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <!-- Profile SSH key (auto-generated) ................. -->
                            <Expander Header="Profile SSH key" IsExpanded="True" Margin="0,8,0,8">
                                <Border Background="{StaticResource PanelBackground}" CornerRadius="6" Padding="16">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,0,0,12">
                                            Per-profile ed25519 keypair. The private seed lives only on
                                            the host (in the agent dir); the guest sees the public key
                                            via the forwarded ssh-agent. Paste the public key into
                                            github.com/settings/keys to use the agent for git over SSH.
                                        </TextBlock>
                                        <Border Background="#F2F2F4" CornerRadius="4" Padding="12">
                                            <TextBox FontFamily="Consolas" FontSize="11"
                                                     IsReadOnly="True" BorderThickness="0"
                                                     Background="Transparent"
                                                     TextWrapping="Wrap"
                                                     Text="{Binding SshPublicKey, Mode=OneWay, FallbackValue='(no key)'}"/>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <Button Content="Copy public key"
                                                    Style="{StaticResource AccentButton}"
                                                    Command="{Binding DataContext.CopySshPublicKeyCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Margin="0,0,8,0"/>
                                            <Button Content="Open GitHub keys page"
                                                    Command="{Binding DataContext.OpenGitHubKeysPageCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Margin="0,0,8,0"/>
                                            <Button Content="Regenerate keypair"
                                                    Style="{StaticResource DangerButton}"
                                                    Command="{Binding DataContext.RegenerateSshKeyCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <!-- Imported SSH keys ................................ -->
                            <Expander Header="Imported SSH keys" Margin="0,8,0,8">
                                <Border Background="{StaticResource PanelBackground}" CornerRadius="6" Padding="16">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                                   Margin="0,0,0,12" TextWrapping="Wrap">
                                            Private keys the host's ssh-agent will sign with on behalf of
                                            the guest. The key bytes never leave the host — only the
                                            agent SIGN_REQUEST protocol crosses to the VM.
                                        </TextBlock>
                                        <ItemsControl ItemsSource="{Binding ImportedSshKeys}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F2F2F4" CornerRadius="4"
                                                            Padding="12" Margin="0,4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                                       Text="{Binding Label}" FontWeight="SemiBold"/>
                                                            <CheckBox Grid.Row="1" Grid.Column="0" Margin="0,8,0,0"
                                                                      Content="Require approval per signature"
                                                                      IsChecked="{Binding RequireApproval}"/>
                                                            <Button Grid.RowSpan="2" Grid.Column="1" Content="Remove"
                                                                    Style="{StaticResource DangerButton}"
                                                                    VerticalAlignment="Center"
                                                                    Command="{Binding DataContext.RemoveSshCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Content="Import SSH key…" Margin="0,12,0,0"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource AccentButton}"
                                                Command="{Binding DataContext.ImportSshKeyCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ================================================
                     ENVIRONMENT TAB
                     ================================================ -->
                <TabItem Header="Environment" Tag="">
                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,0,0,12">
                                Plain environment variables exported into the guest at session
                                launch. Mark "Secret" for values that should be masked in the UI
                                and excluded from screenshots.
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding EnvironmentVariables}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource PanelBackground}"
                                                CornerRadius="4" Padding="12" Margin="0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" FontFamily="Consolas"
                                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                         Margin="0,0,8,0"/>
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                         Margin="0,0,8,0"/>
                                                <CheckBox Grid.Column="2" Content="Secret"
                                                          IsChecked="{Binding IsSecret}"
                                                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <Button Grid.Column="3" Content="Remove"
                                                        Style="{StaticResource DangerButton}"
                                                        Command="{Binding DataContext.RemoveEnvCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="Add environment variable" Margin="0,12,0,0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource AccentButton}"
                                    Command="{Binding DataContext.AddEnvCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ================================================
                     RESOURCES TAB — memory, network, close action
                     ================================================ -->
                <TabItem Header="Resources" Tag="">
                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,0,0,12">
                                VM resources baked at boot. Changing these requires restarting
                                the session — the app will prompt to reboot.
                            </TextBlock>

                            <TextBlock Text="Memory (GiB)" FontWeight="SemiBold" Margin="0,4,0,4"/>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="10"
                                       Margin="0,0,0,4">0 = let the engine pick a default that scales to the host.</TextBlock>
                            <TextBox Width="120" HorizontalAlignment="Left"
                                     Text="{Binding MemoryGB, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Network mode" FontWeight="SemiBold" Margin="0,16,0,4"/>
                            <ComboBox Width="220" HorizontalAlignment="Left"
                                      ItemsSource="{Binding DataContext.NetworkModeOptions,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding NetworkMode}"/>
                            <TextBlock Text="Bridged interface ID (when NetworkMode = Bridged)"
                                       FontSize="10" Foreground="{StaticResource TextSecondary}"
                                       Margin="0,8,0,4"/>
                            <TextBox Width="320" HorizontalAlignment="Left"
                                     Text="{Binding BridgedInterfaceID, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="When closing the session window" FontWeight="SemiBold" Margin="0,16,0,4"/>
                            <ComboBox Width="220" HorizontalAlignment="Left"
                                      ItemsSource="{Binding DataContext.CloseActionOptions,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding CloseAction}"/>

                            <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,16,0,4"/>
                            <TextBox MinHeight="60" AcceptsReturn="True" TextWrapping="Wrap"
                                     Text="{Binding Comments, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ================================================
                     APPEARANCE TAB — cursor, opacity, font, colors
                     ================================================ -->
                <TabItem Header="Appearance" Tag="">
                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,0,0,12">
                                Terminal + window cosmetics. Empty custom fields fall through to
                                the host terminal's defaults when "Inherit from host terminal" is on.
                            </TextBlock>

                            <CheckBox Content="Inherit colors / font from host terminal"
                                      IsChecked="{Binding UseTerminalAppDefaults}"
                                      Margin="0,0,0,12"/>

                            <TextBlock Text="Cursor shape" FontWeight="SemiBold" Margin="0,4,0,4"/>
                            <ComboBox Width="220" HorizontalAlignment="Left"
                                      ItemsSource="{Binding DataContext.CursorShapeOptions,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding CursorShape}"/>

                            <TextBlock Text="Window opacity (0.3 – 1.0)" FontWeight="SemiBold" Margin="0,16,0,4"/>
                            <TextBox Width="120" HorizontalAlignment="Left"
                                     Text="{Binding WindowOpacity, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Custom font family (kitty)" FontWeight="SemiBold" Margin="0,16,0,4"/>
                            <TextBox Width="320" HorizontalAlignment="Left"
                                     Text="{Binding CustomFontFamily, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Custom font size" FontWeight="SemiBold" Margin="0,12,0,4"/>
                            <TextBox Width="120" HorizontalAlignment="Left"
                                     Text="{Binding CustomFontSize, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Background hex (#RRGGBB)" FontWeight="SemiBold" Margin="0,16,0,4"/>
                            <TextBox Width="200" HorizontalAlignment="Left" FontFamily="Consolas"
                                     Text="{Binding CustomBackgroundHex, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Foreground hex (#RRGGBB)" FontWeight="SemiBold" Margin="0,12,0,4"/>
                            <TextBox Width="200" HorizontalAlignment="Left" FontFamily="Consolas"
                                     Text="{Binding CustomForegroundHex, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Keyboard layout override (e.g. fr, ch:fr)" FontWeight="SemiBold" Margin="0,16,0,4"/>
                            <TextBox Width="220" HorizontalAlignment="Left"
                                     Text="{Binding KeyboardLayoutOverride, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ================================================
                     MCP SERVERS TAB
                     Audit 09 #1: macOS Profile.swift has a full MCP
                     editor pane (add / enable / OAuth-authorize); the
                     Windows port had model + builder + broker but no
                     UI surface. This tab adds parity.
                     ================================================ -->
                <TabItem Header="MCP servers" Tag="">
                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,0,0,12">
                                Model Context Protocol servers wired into Claude Code / Codex.
                                Stdio servers run as a child process; HTTP servers are reached
                                over the network with bearer-token auth (the proxy swaps a
                                fake on the wire so the real token never leaves the host).
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding McpServers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource PanelBackground}"
                                                CornerRadius="4" Padding="12" Margin="0,4">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0" FontFamily="Consolas"
                                                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,0,8,0"/>
                                                    <ComboBox Grid.Column="1" MinWidth="100"
                                                              ItemsSource="{Binding DataContext.McpTransportOptions,
                                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              SelectedItem="{Binding Transport}"
                                                              Margin="0,0,8,0"/>
                                                    <CheckBox Grid.Column="2" Content="Enabled"
                                                              IsChecked="{Binding Enabled}"
                                                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <Button Grid.Column="3" Content="Remove"
                                                            Style="{StaticResource DangerButton}"
                                                            Command="{Binding DataContext.RemoveMcpCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                                <!-- Stdio: command + args -->
                                                <StackPanel Visibility="{Binding Transport,
                                                            Converter={StaticResource EnumToVis},
                                                            ConverterParameter=Stdio}">
                                                    <TextBlock Text="Command" FontSize="10"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               Margin="0,4,0,2"/>
                                                    <TextBox FontFamily="Consolas"
                                                             Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <!-- Audit 09 §A6: arguments list. macOS lets the user
                                                         add positional args one at a time; we follow the
                                                         same pattern via an editable line-per-arg list. -->
                                                    <TextBlock Text="Arguments (one per line)" FontSize="10"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               Margin="0,6,0,2"/>
                                                    <TextBox FontFamily="Consolas" FontSize="11"
                                                             AcceptsReturn="True"
                                                             VerticalScrollBarVisibility="Auto"
                                                             MinHeight="50" MaxHeight="120"
                                                             Text="{Binding Arguments,
                                                                    Converter={StaticResource StringListConverter},
                                                                    UpdateSourceTrigger=LostFocus}"/>
                                                </StackPanel>
                                                <!-- HTTP: url + bearer env var -->
                                                <StackPanel Visibility="{Binding Transport,
                                                            Converter={StaticResource EnumToVis},
                                                            ConverterParameter=Http}">
                                                    <TextBlock Text="URL" FontSize="10"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               Margin="0,4,0,2"/>
                                                    <TextBox FontFamily="Consolas"
                                                             Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBlock Text="Bearer-token env var (e.g. MCP_BEARER)"
                                                               FontSize="10"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               Margin="0,6,0,2"/>
                                                    <TextBox FontFamily="Consolas"
                                                             Text="{Binding BearerTokenEnvVar, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBlock Text="Bearer token (proxied — fake substituted on the wire)"
                                                               FontSize="10"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               Margin="0,6,0,2"/>
                                                    <TextBox FontFamily="Consolas"
                                                             Text="{Binding BearerToken, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <!-- Audit 09 §A6: OAuth authorize / revoke. -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                        <Button Content="Authorize…"
                                                                Command="{Binding DataContext.AuthorizeMcpCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Margin="0,0,8,0"/>
                                                        <Button Content="Revoke"
                                                                Style="{StaticResource DangerButton}"
                                                                Command="{Binding DataContext.RevokeMcpOAuthCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </StackPanel>
                                                    <TextBlock FontSize="10"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               Margin="0,6,0,0"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding OAuthState, Converter={StaticResource McpOAuthStatusConverter}}"/>
                                                </StackPanel>
                                                <!-- Audit 09 §A6: per-server environment list. macOS exposes
                                                     a Name=Value editor; we use a NAME=VALUE-per-line text box
                                                     for compactness. Empty lines are dropped on save. -->
                                                <Expander Header="Environment variables" Margin="0,8,0,0">
                                                    <TextBox FontFamily="Consolas" FontSize="11"
                                                             AcceptsReturn="True"
                                                             VerticalScrollBarVisibility="Auto"
                                                             MinHeight="50" MaxHeight="160"
                                                             Text="{Binding Environment,
                                                                    Converter={StaticResource McpEnvLinesConverter},
                                                                    UpdateSourceTrigger=LostFocus}"
                                                             ToolTip="One NAME=VALUE pair per line. Values containing '=' keep the rest of the line as-is."/>
                                                </Expander>
                                                <!-- Audit 09 §A6: raw JSON override. -->
                                                <Expander Header="Raw JSON override" Margin="0,8,0,0">
                                                    <TextBox FontFamily="Consolas" FontSize="11"
                                                             AcceptsReturn="True"
                                                             VerticalScrollBarVisibility="Auto"
                                                             MinHeight="60" MaxHeight="200"
                                                             Text="{Binding RawJson, UpdateSourceTrigger=PropertyChanged}"
                                                             ToolTip="When non-empty, replaces the structured config above. Useful for OAuth blocks and custom MCP shapes."/>
                                                </Expander>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="Add stdio server"
                                        Style="{StaticResource AccentButton}"
                                        Margin="0,0,8,0"
                                        Command="{Binding DataContext.AddMcpStdioCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                <Button Content="Add HTTP server"
                                        Style="{StaticResource AccentButton}"
                                        Command="{Binding DataContext.AddMcpHttpCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- Footer hint -->
            <Border Grid.Row="2" Background="{StaticResource PanelBackground}"
                    BorderBrush="#22000000" BorderThickness="0,1,0,0"
                    Padding="32,10">
                <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                           TextWrapping="Wrap">
                    Edits in this pane persist on every change. The Save button forces
                    an immediate write; Delete removes the profile (and any associated
                    session state) entirely.
                </TextBlock>
            </Border>
        </Grid>

        <!-- Empty state when no profile is selected -->
        <Grid Grid.Column="1" Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="No profile selected" FontSize="14"
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Pick one from the list, or add a new profile."
                           FontSize="11" Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

pipeline {
    agent { label 'macosx-builder' }

    triggers {
        cron('H 5 * * *')  // daily ~5am, an hour after the browser e2e
    }

    environment {
        PATH                   = "/opt/homebrew/bin:${env.PATH}"
        KEYCHAIN_PASSWORD      = credentials('KEYCHAIN_PASSWORD')
        BUILD_KEYCHAIN         = "${HOME}/build.keychain"
        BROMURE_DEBUG_CLAUDE   = '1'
        BROMURE_AC_API_URL     = 'http://127.0.0.1:9223'
    }

    stages {
        stage('Unlock Keychain') {
            steps {
                sh '''
                    security unlock-keychain -p "$KEYCHAIN_PASSWORD" "$BUILD_KEYCHAIN"
                    security list-keychains -s "$BUILD_KEYCHAIN" login.keychain-db
                    security default-keychain -s "$BUILD_KEYCHAIN"
                '''
            }
        }

        stage('Build') {
            steps {
                withCredentials([
                    string(credentialsId: 'DEVELOPER_ID', variable: 'CODESIGN_IDENTITY'),
                    file(credentialsId: 'PROVISION_PROFILE_AC', variable: 'PROVISION_PROFILE')
                ]) {
                    sh '''
                        rm -f bromure-ac.provisionprofile
                        cp "$PROVISION_PROFILE" bromure-ac.provisionprofile
                        ./build.sh bromure-ac 2>&1 | tee build.log
                        grep "^App bundle:" build.log | sed 's/App bundle: //' > .app_bundle_path
                    '''
                }
            }
        }

        stage('Init Base Image') {
            // Needed for sections 6 (Session control) and 8 (VM-side via /exec).
            // Without it those sections gracefully skip but most of the test
            // value is gone — fail the build hard rather than silently degrade.
            steps {
                sh '''
                    APP_BUNDLE=$(cat .app_bundle_path)
                    "$APP_BUNDLE/Contents/MacOS/bromure-ac" init
                '''
            }
        }

        stage('Start App') {
            steps {
                sh '''
                    APP_BUNDLE=$(cat .app_bundle_path)
                    # The automation server is opt-in (off by default) since
                    # it exposes a loopback HTTP surface with no auth. Flip
                    # it on for the CI run via UserDefaults before launch.
                    defaults write io.bromure.agentic-coding automation.enabled -bool true
                    BROMURE_DEBUG_CLAUDE=1 "$APP_BUNDLE/Contents/MacOS/bromure-ac" > /tmp/bromure-ac.log 2>&1 &
                    echo $! > .bromure_ac_pid
                    # Wait up to 60s for the HTTP automation server to come up.
                    for i in $(seq 1 60); do
                        curl -s http://127.0.0.1:9223/health > /dev/null 2>&1 && break
                        sleep 2
                    done
                    curl -s http://127.0.0.1:9223/health || { echo "AC automation API never came up"; exit 1; }
                '''
            }
        }

        stage('Install Test Deps') {
            steps {
                sh '''
                    # Tests/ac-e2e.mjs uses only Node's standard library
                    # (child_process, fetch), so socket npm ci is a no-op
                    # against the existing Tests/package-lock.json. Run it
                    # anyway so any future dep additions land deterministically.
                    command -v socket > /dev/null 2>&1 || npm install -g @socketsecurity/cli
                    cd Tests && socket npm ci
                '''
            }
        }

        stage('1. App state') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^1\\."'
                }
            }
        }

        stage('2. Profile CRUD') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^2\\."'
                }
            }
        }

        stage('3. Profile JSON') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^3\\."'
                }
            }
        }

        stage('4. Editor windowing') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^4\\."'
                }
            }
        }

        stage('5. HTTP automation API') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^5\\."'
                }
            }
        }

        stage('6. Session control') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^6\\."'
                }
            }
        }

        stage('7. App-wide settings') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^7\\."'
                }
            }
        }

        stage('8. VM-side via /exec') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^8\\."'
                }
            }
        }

        stage('9. Supply Chain Security (JSON/live)') {
            // Plumbing tests — no VM required. Run before section 10
            // so a failure in the JSON layer surfaces quickly without
            // burning a full VM-boot cycle on the diagnostic.
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^9\\."'
                }
            }
        }

        stage('10. Supply Chain Security (VM-side)') {
            // End-to-end through a session VM with the proxy active:
            //   - npm/PyPI metadata rewrites tagged with the
            //     `X-Bromure-Rewritten` response header,
            //   - npm tarball script-strip leaves a valid archive,
            //   - per-package allowlist suppresses rewriting,
            //   - policy-off → no rewriting,
            //   - 451 response carries the Bromure attribution body.
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^10\\."'
                }
            }
        }

        stage('11. Prompt Injection (policy)') {
            // Plumbing tests — no VM required. The per-profile
            // PromptInjectionPolicy round-trips through profile JSON
            // (default-off, toggles, action enum, tolerant decode).
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^11\\."'
                }
            }
        }

        stage('12. Prompt Injection (detection)') {
            // Drives the real detectors through /detect/prompt-injection
            // (needs BROMURE_DEBUG_CLAUDE, set above). Heuristic assertions
            // are deterministic; the ONNX-model assertions self-skip when the
            // model isn't installed in CI (gated on `modelInstalled`).
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^12\\."'
                }
            }
        }

        stage('13. CLI plumbing') {
            // `bromure-ac` subcommands over the owner-only control socket:
            // vm ls, info, profiles ls/describe/rm, trace ls/summary/hostnames/
            // clear, and the vm fusion guards. No VM required.
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^13\\."'
                }
            }
        }

        stage('14. Profile options') {
            // JSON round-trip for the new profile settings: closeAction
            // (background/suspend/shutdown, default ask), bootAtStartup,
            // startInBackground. No VM required.
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^14\\."'
                }
            }
        }

        stage('15. CLI VM lifecycle') {
            // Boots VMs via the CLI (needs the base image from the Init stage):
            // vm run/ls/exec/describe (MAC + IP), stable IP across stop/restart
            // (sqlite DHCP lease), startInBackground = detached boot, and the
            // profiles-rm-while-running guard.
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'node Tests/ac-e2e.mjs --filter "^15\\."'
                }
            }
        }
    }

    post {
        always {
            sh '''
                if [ -f .bromure_ac_pid ]; then
                    kill "$(cat .bromure_ac_pid)" 2>/dev/null || true
                    rm -f .bromure_ac_pid
                fi
                security default-keychain -s login.keychain-db || true
            '''
            archiveArtifacts artifacts: '/tmp/bromure-ac.log', allowEmptyArchive: true
        }
    }
}

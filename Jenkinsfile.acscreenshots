pipeline {
    agent { label 'macosx-builder' }


    environment {
        PATH               = "/opt/homebrew/bin:/Users/jenkins/.local/bin:${env.PATH}"
        KEYCHAIN_PASSWORD   = credentials('KEYCHAIN_PASSWORD')
        BUILD_KEYCHAIN      = "${HOME}/build.keychain"
        ANTHROPIC_API_KEY   = credentials('ANTHROPIC_API_KEY')
    }

    stages {
        stage('Unlock Keychain') {
            steps {
                sh '''
                    security unlock-keychain -p "$KEYCHAIN_PASSWORD" "$BUILD_KEYCHAIN"
                    security list-keychains -s "$BUILD_KEYCHAIN" login.keychain-db
                    security default-keychain -s "$BUILD_KEYCHAIN"
                '''
            }
        }

        stage('Build') {
            steps {
                withCredentials([
                    string(credentialsId: 'DEVELOPER_ID', variable: 'CODESIGN_IDENTITY'),
                    file(credentialsId: 'PROVISION_PROFILE_AC', variable: 'PROVISION_PROFILE')
                ]) {
                    sh '''
                        rm -f bromure-ac.provisionprofile
                        cp "$PROVISION_PROFILE" bromure-ac.provisionprofile
                        ./build.sh bromure-ac 2>&1 | tee build.log
                    '''
                }
            }
        }

        stage('Take Screenshots') {
            steps {
                sh './scripts/take-ac-screenshots.sh'
            }
        }

        stage('Update SETTINGS_AGENTIC.md') {
            steps {
                sh '''
                    claude -p "Look at every English screenshot in Resources/ac/editor_*_en.jpg and compare them to what is currently documented in SETTINGS_AGENTIC.md. If SETTINGS_AGENTIC.md does not exist yet, create it modeled on SETTINGS.md's structure (one section per editor category with a table of settings). Every editor category screenshot must have its own section: if a screenshot exists for a category that has no section yet (for example the Fusion panel, editor_fusion_en.jpg), add a new section for it modeled on the existing ones — heading, centered <img> tag pointing at that category's screenshot, a short intro paragraph, and a settings table. Note any BETA badge shown in the screenshot in the intro. Add any new settings that appear in the screenshots but are missing from the documentation. Use the Swift source code in Sources/AgentCoding/ for accurate descriptions. Only edit settings tables and add missing category sections — do not reorder or rewrite unrelated sections, change image paths, or remove any existing entries." \
                        --allowedTools 'Read,Edit,Write,Grep,Glob' \
                        --max-turns 30
                '''
            }
        }

        stage('Commit') {
            steps {
                sh '''
                    git add Resources/ac/editor_*.jpg SETTINGS_AGENTIC.md
                    if git diff --cached --quiet; then
                        echo "No changes to commit"
                    else
                        git commit -m "Update AC editor screenshots and documentation

Automated weekly refresh of Bromure Agentic Coding editor
screenshots across all 8 locales, with SETTINGS_AGENTIC.md
updated to reflect any new or changed settings.

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>"
                        git push origin HEAD:refs/heads/${GIT_BRANCH#*/}
                    fi
                '''
            }
        }
    }

    post {
        always {
            sh '''
                pkill -x bromure-ac 2>/dev/null || true
                security default-keychain -s login.keychain-db || true
            '''
            archiveArtifacts artifacts: 'Resources/ac/editor_*.jpg, SETTINGS_AGENTIC.md', allowEmptyArchive: true
        }
    }
}

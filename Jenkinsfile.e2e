pipeline {
    agent { label 'macosx-builder' }

    triggers {
        cron('H 4 * * *')  // daily at ~4am
    }

    environment {
        PATH                   = "/opt/homebrew/bin:${env.PATH}"
        KEYCHAIN_PASSWORD      = credentials('KEYCHAIN_PASSWORD')
        BUILD_KEYCHAIN         = "${HOME}/build.keychain"
        BROMURE_DEBUG_CLAUDE   = '1'
    }

    stages {
        stage('Unlock Keychain') {
            steps {
                sh '''
                    security unlock-keychain -p "$KEYCHAIN_PASSWORD" "$BUILD_KEYCHAIN"
                    security list-keychains -s "$BUILD_KEYCHAIN" login.keychain-db
                    security default-keychain -s "$BUILD_KEYCHAIN"
                '''
            }
        }

        stage('Build') {
            steps {
                withCredentials([
                    string(credentialsId: 'DEVELOPER_ID', variable: 'CODESIGN_IDENTITY'),
                    file(credentialsId: 'PROVISION_PROFILE', variable: 'PROVISION_PROFILE')
                ]) {
                    sh '''
                        rm -f bromure.provisionprofile
                        cp "$PROVISION_PROFILE" bromure.provisionprofile
                        ./build.sh 2>&1 | tee build.log
                        grep "^App bundle:" build.log | sed 's/App bundle: //' > .app_bundle_path
                    '''
                }
            }
        }

        stage('Init Base Image') {
            steps {
                sh '''
                    APP_BUNDLE=$(cat .app_bundle_path)
                    "$APP_BUNDLE/Contents/MacOS/bromure" init
                '''
            }
        }

        stage('Start App') {
            steps {
                sh '''
                    APP_BUNDLE=$(cat .app_bundle_path)
                    BROMURE_DEBUG_CLAUDE=y "$APP_BUNDLE/Contents/MacOS/bromure" &
                    echo $! > .bromure_pid
                    for i in $(seq 1 60); do
                        curl -s http://127.0.0.1:9222/ > /dev/null 2>&1 && break
                        sleep 2
                    done
                '''
            }
        }

        stage('Install Test Deps') {
            steps {
                sh '''
                    command -v socket > /dev/null 2>&1 || npm install -g @socketsecurity/cli
                    cd Tests && socket npm ci
                '''
            }
        }

        stage('Verify Kernel Modules') {
            steps {
                sh '''
                    SID=$(curl -sf -X POST http://127.0.0.1:9222/sessions \
                        -H 'Content-Type: application/json' \
                        -d '{"profile":"Default"}' \
                        | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])")

                    # Wait for shell agent to become available (exec endpoint retries for 10s internally)
                    sleep 5

                    exec_vm() {
                        curl -sf -X POST "http://127.0.0.1:9222/sessions/$SID/exec" \
                            -H 'Content-Type: application/json' \
                            -d "{\"command\":\"$1\",\"timeout\":30}"
                    }

                    echo "Loading v4l2loopback..."
                    R=$(exec_vm "modprobe v4l2loopback video_nr=0 card_label=test exclusive_caps=1")
                    EC=$(echo "$R" | python3 -c "import sys,json; print(json.load(sys.stdin).get('exitCode',1))")
                    [ "$EC" = "0" ] || { echo "FAIL: v4l2loopback did not load (exit $EC)"; echo "$R"; exit 1; }

                    echo "Loading rtc-pl031..."
                    R=$(exec_vm "modprobe rtc-pl031")
                    EC=$(echo "$R" | python3 -c "import sys,json; print(json.load(sys.stdin).get('exitCode',1))")
                    [ "$EC" = "0" ] || { echo "FAIL: rtc-pl031 did not load (exit $EC)"; echo "$R"; exit 1; }

                    echo "Verifying modules are loaded..."
                    R=$(exec_vm "lsmod")
                    STDOUT=$(echo "$R" | python3 -c "import sys,json; print(json.load(sys.stdin).get('stdout',''))")
                    echo "$STDOUT" | grep -q v4l2loopback || { echo "FAIL: v4l2loopback not in lsmod"; exit 1; }
                    echo "$STDOUT" | grep -q rtc_pl031 || { echo "FAIL: rtc_pl031 not in lsmod"; exit 1; }

                    echo "OK: v4l2loopback and rtc-pl031 loaded successfully"

                    curl -sf -X DELETE "http://127.0.0.1:9222/sessions/$SID" > /dev/null 2>&1 || true
                '''
            }
        }

        stage('0. Automation Server') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^0\\."'
                }
            }
        }

        stage('1. Profile Management') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^1\\."'
                }
            }
        }

        stage('2. App Settings') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^2\\."'
                }
            }
        }

        stage('3. Home Page') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^3\\."'
                }
            }
        }

        stage('4. Performance (GPU/WebGL)') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^4\\."'
                }
            }
        }

        stage('5. Appearance') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^5\\."'
                }
            }
        }

        stage('6. Media (Audio/Webcam)') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^6\\."'
                }
            }
        }

        stage('7. Clipboard') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^7\\."'
                }
            }
        }

        stage('8. Privacy & Safety') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^8\\."'
                }
            }
        }

        stage('9. File Transfer') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^9\\."'
                }
            }
        }

        stage('10. WARP VPN') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^10\\."'
                }
            }
        }

        stage('11. Enterprise (Proxy/Certs)') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^11\\."'
                }
            }
        }

        stage('12. Language/Locale') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^12\\."'
                }
            }
        }

        stage('13. VM Internals') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^13\\."'
                }
            }
        }

        stage('14. Session Lifecycle') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^14\\."'
                }
            }
        }

        stage('15. Automation API') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^15\\."'
                }
            }
        }

        stage('16. Allow Automation Flag') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^16\\."'
                }
            }
        }

        stage('17. Session Recording (Trace)') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^17\\."'
                }
            }
        }

        stage('18. Heavy Page Regression') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^18\\."'
                }
            }
        }

        stage('19. Keyboard Layout') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^19\\."'
                }
            }
        }

        stage('20. Networking') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'cd Tests && node e2e.mjs --filter "^20\\."'
                }
            }
        }
    }

    post {
        always {
            sh '''
                if [ -f .bromure_pid ]; then
                    kill "$(cat .bromure_pid)" 2>/dev/null || true
                    rm -f .bromure_pid
                fi
                security default-keychain -s login.keychain-db || true
            '''
        }
    }
}
